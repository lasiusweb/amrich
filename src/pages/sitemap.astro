---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.ts';
import { categories } from '../data/products.ts';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Sitemap | AMRich Aquaculture Solutions",
  "description": "Complete sitemap of AMRich Aquaculture Solutions website.",
  "url": `${site.url}/sitemap/`,
};
---

<BaseLayout
  title="Sitemap | AMRich Aquaculture Solutions"
  description="Complete sitemap of AMRich Aquaculture Solutions website."
  schema={schema}
>
  <Header />

  <main class="flex-1">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Sitemap' },
    ]} />

    <section class="section-padding">
      <div class="container-wide max-w-4xl">
        <h1 class="text-4xl font-extrabold text-primary-800 mb-8">Sitemap</h1>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Main Pages -->
          <div>
            <h2 class="text-lg font-bold text-primary-800 mb-4">Main Pages</h2>
            <ul class="space-y-2">
              <li><a href="/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">Home</a></li>
              <li><a href="/about/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">About Us</a></li>
              <li><a href="/contact/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">Contact</a></li>
              <li><a href="/how-to-order/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">How to Order</a></li>
              <li><a href="/faq/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">FAQ</a></li>
              <li><a href="/case-studies/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">Case Studies</a></li>
              <li><a href="/resources/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">Resources</a></li>
            </ul>
          </div>

          <!-- Products -->
          <div>
            <h2 class="text-lg font-bold text-primary-800 mb-4">Products</h2>
            <ul class="space-y-2">
              <li><a href="/products/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">All Products</a></li>
              <li><a href="/species/shrimp/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">Shrimp Products</a></li>
              <li><a href="/species/fish/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">Fish Products</a></li>
              {categories.map((cat) => (
                <li>
                  <a href={`/products/${cat.slug}/`} class="text-gray-600 hover:text-primary-800 text-sm transition-colors">
                    {cat.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Individual Products -->
          <div>
            <h2 class="text-lg font-bold text-primary-800 mb-4">Product Details</h2>
            <ul class="space-y-2">
              {categories.map((cat) => (
                <>
                  {cat.products.map((p) => (
                    <li>
                      <a href={`/products/${cat.slug}/${p.slug}/`} class="text-gray-600 hover:text-primary-800 text-sm transition-colors">
                        {p.name}
                      </a>
                    </li>
                  ))}
                </>
              ))}
            </ul>
          </div>

          <!-- Blog -->
          <div>
            <h2 class="text-lg font-bold text-primary-800 mb-4">Blog</h2>
            <ul class="space-y-2">
              <li><a href="/blog/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">All Articles</a></li>
              <li><a href="/blog/shrimp-disease-prevention-guide/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">Shrimp Disease Prevention Guide</a></li>
              <li><a href="/blog/control-ammonia-shrimp-ponds/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">How to Control Ammonia</a></li>
              <li><a href="/blog/biofloc-technology-beginners-guide/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">Biofloc Technology Guide</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <h2 class="text-lg font-bold text-primary-800 mb-4">Legal</h2>
            <ul class="space-y-2">
              <li><a href="/privacy/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">Privacy Policy</a></li>
              <li><a href="/terms/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">Terms of Service</a></li>
            </ul>
          </div>

          <!-- Species -->
          <div>
            <h2 class="text-lg font-bold text-primary-800 mb-4">By Species</h2>
            <ul class="space-y-2">
              <li><a href="/species/shrimp/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">Shrimp Farming</a></li>
              <li><a href="/species/fish/" class="text-gray-600 hover:text-primary-800 text-sm transition-colors">Fish Farming</a></li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
