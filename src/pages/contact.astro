---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.ts';

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Amrich Pharma",
  "description": "Get in touch with Amrich Pharma for product inquiries, technical support, and partnership opportunities.",
  "url": `${site.url}/contact`,
};
---

<BaseLayout
  title="Contact Us | Amrich Pharma"
  description="Get in touch with Amrich Pharma for product inquiries, technical support, and partnership opportunities."
  schema={schema}
>
  <Header />

  <main id="main-content" class="flex-1">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Contact' },
    ]} />

    <section class="bg-gradient-to-br from-brand-900 via-brand-800 to-ocean-900 text-white py-20">
      <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">
            Contact Us
          </h1>
          <p class="text-lg text-white/70 leading-relaxed">
            Have a question about our products or need technical support? We're here to help.
          </p>
        </div>
      </div>
    </section>

    <section class="section-padding">
      <div class="container-wide max-w-4xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div>
            <h2 class="font-display text-2xl font-bold text-ink mb-6">Send Us a Message</h2>
            <form class="space-y-4" action="https://formspree.io/f/xeojqvak" method="POST">
              <div>
                <label for="name" class="block text-sm font-medium text-ink mb-1">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-2.5 rounded-xl border border-border bg-surface text-ink placeholder:text-ink-light/50 focus:outline-none focus:ring-2 focus:ring-brand-500 transition-shadow"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-ink mb-1">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-2.5 rounded-xl border border-border bg-surface text-ink placeholder:text-ink-light/50 focus:outline-none focus:ring-2 focus:ring-brand-500 transition-shadow"
                />
              </div>
              <div>
                <label for="subject" class="block text-sm font-medium text-ink mb-1">Subject</label>
                <select
                  id="subject"
                  name="subject"
                  class="w-full px-4 py-2.5 rounded-xl border border-border bg-surface text-ink focus:outline-none focus:ring-2 focus:ring-brand-500 transition-shadow"
                >
                  <option value="general">General Inquiry</option>
                  <option value="products">Product Information</option>
                  <option value="technical">Technical Support</option>
                  <option value="partnership">Partnership</option>
                </select>
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-ink mb-1">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full px-4 py-2.5 rounded-xl border border-border bg-surface text-ink placeholder:text-ink-light/50 focus:outline-none focus:ring-2 focus:ring-brand-500 transition-shadow resize-vertical"
                ></textarea>
              </div>
              <button
                type="submit"
                class="w-full inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-semibold text-white bg-brand-600 rounded-xl hover:bg-brand-700 transition-colors focus-ring"
              >
                Send Message
                <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </button>
            </form>
          </div>

          <div>
            <h2 class="font-display text-2xl font-bold text-ink mb-6">Get in Touch</h2>
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="size-10 rounded-xl bg-brand-50 dark:bg-brand-900/20 flex items-center justify-center shrink-0">
                  <svg class="size-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-ink text-sm">Email</h3>
                  <a href={`mailto:${site.email}`} class="text-sm text-ink-light hover:text-brand-600 transition-colors">
                    {site.email}
                  </a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="size-10 rounded-xl bg-brand-50 dark:bg-brand-900/20 flex items-center justify-center shrink-0">
                  <svg class="size-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-ink text-sm">Phone</h3>
                  <span class="text-sm text-ink-light">{site.phone}</span>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="size-10 rounded-xl bg-brand-50 dark:bg-brand-900/20 flex items-center justify-center shrink-0">
                  <svg class="size-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-ink text-sm">Location</h3>
                  <span class="text-sm text-ink-light">{site.location}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
