---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Page Not Found | Amrich Pharma"
  description="The page you're looking for doesn't exist. Browse our aquaculture products and resources."
>
  <Header />

  <main id="main-content" class="flex-1">
    <section class="section-padding">
      <div class="container-wide max-w-2xl text-center">
        <div class="size-20 rounded-2xl bg-brand-50 dark:bg-brand-900/20 flex items-center justify-center mx-auto mb-6">
          <svg class="size-10 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <h1 class="font-display text-6xl font-bold text-ink mb-2">404</h1>
        <p class="text-lg text-ink-light mb-10">
          The page you're looking for doesn't exist or has been moved.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-14">
          <a
            href="/"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-semibold text-white bg-brand-600 rounded-xl hover:bg-brand-700 transition-colors focus-ring"
          >
            Back to Home
          </a>
          <a
            href="/products/"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-semibold text-brand-600 bg-surface border-2 border-brand-600 rounded-xl hover:bg-brand-50 dark:hover:bg-brand-900/20 transition-colors focus-ring"
          >
            Browse Products
          </a>
        </div>

        <div class="bg-surface-muted border border-border rounded-2xl p-8">
          <h2 class="text-lg font-bold text-ink mb-4">Popular Pages</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-left">
            <a href="/products/disease-stress-management/" class="flex items-center gap-2 text-sm text-ink-light hover:text-brand-600 transition-colors">
              <span>🛡️</span>
              <span>Disease Management</span>
            </a>
            <a href="/products/water-quality-ammonia-control/" class="flex items-center gap-2 text-sm text-ink-light hover:text-brand-600 transition-colors">
              <span>💧</span>
              <span>Water Quality</span>
            </a>
            <a href="/products/probiotics-soil-care/" class="flex items-center gap-2 text-sm text-ink-light hover:text-brand-600 transition-colors">
              <span>🦠</span>
              <span>Probiotics & Soil Care</span>
            </a>
            <a href="/products/feed-pond-preparers/" class="flex items-center gap-2 text-sm text-ink-light hover:text-brand-600 transition-colors">
              <span>🐟</span>
              <span>Feed & Pond Preparers</span>
            </a>
            <a href="/blog/" class="flex items-center gap-2 text-sm text-ink-light hover:text-brand-600 transition-colors">
              <span>📖</span>
              <span>Blog</span>
            </a>
            <a href="/contact/" class="flex items-center gap-2 text-sm text-ink-light hover:text-brand-600 transition-colors">
              <span>📞</span>
              <span>Contact Us</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
