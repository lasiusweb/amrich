---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Page Not Found | AMRich Aquaculture Solutions"
  description="The page you're looking for doesn't exist. Browse our aquaculture products and resources."
>
  <Header />

  <main class="flex-1">
    <section class="section-padding">
      <div class="container-wide max-w-2xl text-center">
        <div class="text-8xl mb-6">🔍</div>
        <h1 class="text-6xl font-extrabold text-primary-800 mb-4">404</h1>
        <p class="text-xl text-gray-600 mb-8">
          The page you're looking for doesn't exist or has been moved.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
          <a
            href="/"
            class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-primary-800 rounded-lg shadow-lg hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-all duration-200"
          >
            Back to Home
          </a>
          <a
            href="/products/"
            class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-primary-800 bg-white border-2 border-primary-800 rounded-lg hover:bg-primary-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-all duration-200"
          >
            Browse Products
          </a>
        </div>

        <div class="bg-gray-50 rounded-xl p-8">
          <h2 class="text-lg font-bold text-primary-800 mb-4">Popular Pages</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-left">
            <a href="/products/disease-stress-management/" class="flex items-center space-x-2 text-gray-600 hover:text-primary-800 transition-colors">
              <span>🛡️</span>
              <span class="text-sm">Disease Management</span>
            </a>
            <a href="/products/water-quality-ammonia-control/" class="flex items-center space-x-2 text-gray-600 hover:text-primary-800 transition-colors">
              <span>💧</span>
              <span class="text-sm">Water Quality</span>
            </a>
            <a href="/products/probiotics-soil-care/" class="flex items-center space-x-2 text-gray-600 hover:text-primary-800 transition-colors">
              <span>🦠</span>
              <span class="text-sm">Probiotics & Soil Care</span>
            </a>
            <a href="/products/feed-pond-preparers/" class="flex items-center space-x-2 text-gray-600 hover:text-primary-800 transition-colors">
              <span>🐟</span>
              <span class="text-sm">Feed & Pond Preparers</span>
            </a>
            <a href="/blog/" class="flex items-center space-x-2 text-gray-600 hover:text-primary-800 transition-colors">
              <span>📖</span>
              <span class="text-sm">Blog</span>
            </a>
            <a href="/contact/" class="flex items-center space-x-2 text-gray-600 hover:text-primary-800 transition-colors">
              <span>📞</span>
              <span class="text-sm">Contact Us</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
