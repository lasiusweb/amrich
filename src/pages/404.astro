---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found | Amrich Pharma" description="Get back on track with quick links to products, support, or WhatsApp help.">
  <section class="hero-band-dark" style="text-align: center;">
    <div class="container">
      <h1>Page Not Found</h1>
      <p style="color: var(--on-dark-soft); margin-top: var(--space-sm); max-width: 500px; margin-left: auto; margin-right: auto;">
        Don't worry — your pond is still thriving. Let's get you back on track.
      </p>
    </div>
  </section>

  <section class="section-padding">
    <div class="container" style="max-width: 600px;">
      <h2 style="text-align: center;">Quick Links</h2>
      <div style="margin-top: var(--space-lg); display: grid; gap: var(--space-sm);">
        <a href="/products" class="btn-secondary" style="width: 100%;">Browse All Products</a>
        <a href="/resources/seasonal-guides/monsoon-aquaculture-stress-guide" class="btn-secondary" style="width: 100%;">Monsoon Stress Guide</a>
        <a href="/resources/problem-solution/ammonia-nitrite-spike-removal" class="btn-secondary" style="width: 100%;">Ammonia Spike Help</a>
        <a href="https://wa.me/919712335338" class="btn-primary" style="width: 100%;" target="_blank" rel="noopener noreferrer">WhatsApp Support</a>
      </div>

      <div style="margin-top: var(--space-xxl);">
        <h3 style="text-align: center;">Search Our Site</h3>
        <form action="/search" method="get" style="margin-top: var(--space-sm); display: flex; gap: var(--space-xs);">
          <input type="search" name="q" placeholder="Search products, guides..." style="flex: 1; padding: var(--space-sm); border: 1px solid var(--hairline); border-radius: var(--rounded-sm); font-family: var(--font-sans); font-size: 16px;" />
          <button type="submit" class="btn-primary">Search</button>
        </form>
      </div>

      <div style="margin-top: var(--space-xxl); text-align: center;">
        <h3>Still Need Help?</h3>
        <p style="margin-top: var(--space-sm); color: var(--muted);">
          Call or message us — we respond within minutes
        </p>
        <div style="margin-top: var(--space-base); display: flex; gap: var(--space-base); justify-content: center; flex-wrap: wrap;">
          <a href="https://wa.me/919712335338" class="btn-primary" target="_blank" rel="noopener noreferrer">WhatsApp</a>
          <a href="tel:+919712335338" class="btn-secondary">Call 97123 35338</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
