---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/icons/Icon.astro';
const org = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Testimonials | Real Results from Coastal Farmers',
  description: 'Real results from Indian coastal farmers using Amrich Pharma products: ammonia reduction, improved survival rates, higher yields per acre.',
  publisher: {
    '@type': 'Organization',
    name: 'Amrich Pharma',
    address: { '@type': 'PostalAddress', streetAddress: 'Plot No. 2, Sainath Nagar, Shivaji Mandpeshwar Road, Dahisar', addressLocality: 'Mumbai', addressRegion: 'Maharashtra', postalCode: '400068', addressCountry: 'IN' },
    email: 'amrichpharma@gmail.com',
    telephone: '+919712335338',
  },
};
const testimonials = [
  {
    location: 'Kakinada, AP | Shrimp Farm (12 Acres)',
    quote: 'After using PRO PLUS + GASO CLEAN, ammonia dropped from 2.1 to 0.4 ppm in 5 days. Survival rate improved by 18% this cycle.',
    farmer: 'Ramesh K., Commercial Grower',
  },
  {
    location: 'Nellore, TN | Tiger Prawn Farm',
    quote: 'FARM 80% cleared gill rot without shocking the pond. Moulting became uniform. Yield per acre went up by 120 kg.',
    farmer: 'S. Venkat, Mid-Scale Farmer',
  },
  {
    location: 'Ongole, AP | Fish Pond (8 Acres)',
    quote: 'W-SOFTENER stabilized our pH within 24 hours during the monsoon. We didn\u2019t lose a single fish. Unbelievable results.',
    farmer: 'M. Prasad, Freshwater Farmer',
  },
  {
    location: 'Bhatkal, KA | Shrimp Hatchery',
    quote: 'SHRIMP CARE reduced molt death syndrome by 40%. Our post-larvae survival jumped from 65% to 88%. Highly recommend.',
    farmer: 'K. Shetty, Hatchery Owner',
  },
];
const metrics = [
  { label: 'Ammonia', before: '1.8 ppm', after: '0.3 ppm', icon: 'water' as const },
  { label: 'DO Levels', before: '3.2 mg/L', after: '5.8 mg/L', icon: 'pond' as const },
  { label: 'Feed Conversion Ratio', before: '1.9', after: '1.4', icon: 'harvest' as const },
  { label: 'Mortality', before: '22%', after: '8%', icon: 'leaf' as const },
];
---

<Layout title="Testimonials | Real Results from Coastal Farmers" description="Real farmer testimonials: ammonia reduction, higher survival rates, improved FCR, and increased yields with Amrich Pharma aquaculture solutions.">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(org)} />

  <section class="testimonials-hero-section">
    <div class="t-hero-bg">
      <img src="https://www.globalseafood.org/wp-content/uploads/2019/10/India-shrimp-ponds_1500.jpg" alt="Farmer at pond" class="hero-bg-img" width="1600" height="900" loading="eager" fetchpriority="high" decoding="async" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <h1>Real Ponds. Real Results.</h1>
      <p class="hero-sub">Don't just take our word for it. Here's what coastal farmers report after switching to Amrich Pharma solutions.</p>
    </div>
  </section>

  <section class="section-padding">
    <div class="container">
      <div class="testimonials-grid">
        {testimonials.map(t => (
          <div class="card testimonial-card">
            <div class="testimonial-header">
              <div class="farmer-avatar">
                <Icon name="farmer" size={20} />
              </div>
              <p class="testimonial-location">{t.location}</p>
            </div>
            <blockquote class="testimonial-quote">&ldquo;{t.quote}&rdquo;</blockquote>
            <p class="testimonial-farmer">&mdash; {t.farmer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="surface-soft section-padding">
    <div class="container">
      <h2 class="metrics-heading">Average Improvement Across Partner Farms</h2>
      <div class="metrics-grid">
        {metrics.map(m => (
          <div class="card metric-card">
            <div class="metric-icon"><Icon name={m.icon} size={18} /></div>
            <h3>{m.label}</h3>
            <div class="metric-values">
              <span class="metric-before">{m.before}</span>
              <span class="metric-arrow">&rarr;</span>
              <span class="metric-after">{m.after}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container testimonials-cta" style="text-align: center;">
      <div style="display: flex; flex-wrap: wrap; gap: var(--space-sm); justify-content: center;">
        <button class="btn-primary" data-modal="quote-form">Submit Your Pond Results</button>
        <button class="btn-secondary" data-modal="quote-form">Book a Free Pond Audit</button>
      </div>
    </div>
  </section>
</Layout>

<style>
  .testimonials-hero-section {
    position: relative;
    min-height: 40dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .t-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .t-hero-bg .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(10,11,13,0.85) 0%, rgba(10,11,13,0.6) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    padding: var(--space-xxl) 0;
  }
  .hero-content h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    color: var(--on-dark);
    letter-spacing: -1px;
    margin-bottom: var(--space-lg);
  }
  .hero-sub {
    font-size: 1.1rem;
    color: var(--on-dark-soft);
    line-height: 1.6;
  }
  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-base);
  }
  .testimonial-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .testimonial-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  .farmer-avatar {
    width: 36px;
    height: 36px;
    background: var(--primary);
    color: var(--on-primary);
    border-radius: var(--rounded-full);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .testimonial-location {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
    font-weight: 500;
  }
  .testimonial-quote {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--ink);
    line-height: 1.6;
    font-style: normal;
    border-left: 3px solid var(--primary);
    padding-left: var(--space-base);
  }
  .testimonial-farmer {
    font-size: 0.9rem;
    color: var(--body);
    font-weight: 500;
  }
  .metrics-heading {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--ink);
    text-align: center;
    margin-bottom: var(--space-xl);
  }
  .metrics-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-base);
  }
  .metric-card {
    text-align: center;
    position: relative;
    padding-top: var(--space-lg);
  }
  .metric-icon {
    width: 36px;
    height: 36px;
    background: var(--surface-strong);
    color: var(--primary);
    border-radius: var(--rounded-full);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-sm);
  }
  .metric-card h3 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
    margin-bottom: var(--space-sm);
  }
  .metric-values {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-size: 1.25rem;
    font-weight: 600;
  }
  .metric-before {
    color: var(--semantic-down);
    text-decoration: line-through;
  }
  .metric-arrow {
    color: var(--muted-soft);
  }
  .metric-after {
    color: var(--semantic-up);
  }
  @media (min-width: 768px) {
    .hero-content h1 { font-size: 3.25rem; }
    .testimonials-grid { grid-template-columns: 1fr 1fr; }
    .metrics-grid { grid-template-columns: 1fr 1fr; }
    .metrics-heading { font-size: 1.75rem; }
  }
</style>
