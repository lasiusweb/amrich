---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/icons/Icon.astro';
const org = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Sustainability | Amrich Pharma',
  description: 'Amrich Pharma is committed to eco-safe aquaculture: biodegradable packaging, zero harmful runoff, carbon-neutral logistics, and farmer training programs.',
  publisher: {
    '@type': 'Organization',
    name: 'Amrich Pharma',
    address: { '@type': 'PostalAddress', streetAddress: 'Plot No. 2, Sainath Nagar, Shivaji Mandpeshwar Road, Dahisar', addressLocality: 'Mumbai', addressRegion: 'Maharashtra', postalCode: '400068', addressCountry: 'IN' },
    email: 'amrichpharma@gmail.com',
    telephone: '+919712335338',
  },
};
const commitments = [
  { title: 'Biodegradable Packaging', desc: 'Recyclable pouches &amp; reduced plastic waste', icon: 'leaf' },
  { title: 'Zero Harmful Runoff', desc: 'Microbial &amp; herbal blends that break down safely', icon: 'water' },
  { title: 'Carbon-Neutral Logistics', desc: 'Optimized routing for coastal distribution', icon: 'harvest' },
  { title: 'Water Conservation Tech', desc: 'Formulations that maintain DO &amp; reduce flush cycles', icon: 'pond' },
  { title: 'Farmer Training Programs', desc: 'Free pond management workshops &amp; digital guides', icon: 'farmer' },
];
---

<Layout title="Sustainability | Amrich Pharma" description="Amrich Pharma's sustainability commitments: biodegradable packaging, zero chemical runoff, carbon-neutral logistics, water conservation, and farmer training.">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(org)} />

  <section class="sustainability-hero-section">
    <div class="sus-hero-bg">
      <img src="https://sharangaaqua.com/images/operation4.jpg" alt="Sustainable aquaculture pond" class="hero-bg-img" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <h1>Farming Forward. Without Compromise.</h1>
      <p class="hero-sub">Healthy ponds shouldn't cost the earth. At Amrich Pharma, sustainability isn't an add-on — it's built into every formula, package, and delivery.</p>
    </div>
  </section>

  <section class="section-padding">
    <div class="container">
      <div class="commitments-grid">
        {commitments.map(c => (
          <div class="card commitment-card">
            <div class="commitment-icon"><Icon name={c.icon} size={22} /></div>
            <div>
              <h3>{c.title}</h3>
              <p>{c.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="sustainability-closing">
        <p>We partner with local fisheries departments, research institutes, and coastal cooperatives to ensure every product supports long-term aquatic ecosystem balance.</p>
      </div>

      <div class="sustainability-cta" style="text-align: center; margin-top: var(--space-xxl);">
        <button class="btn-primary" data-modal="quote-form">Join Our Farmer Network</button>
      </div>
    </div>
  </section>
</Layout>

<style>
  .sustainability-hero-section {
    position: relative;
    min-height: 40dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .sus-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .sus-hero-bg .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(10,11,13,0.85) 0%, rgba(10,11,13,0.6) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    padding: var(--space-xxl) 0;
  }
  .hero-content h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    color: var(--on-dark);
    letter-spacing: -1px;
    line-height: 1.15;
    margin-bottom: var(--space-lg);
  }
  .hero-sub {
    font-size: 1.1rem;
    color: var(--on-dark-soft);
    line-height: 1.6;
  }
  .commitments-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-base);
    margin-bottom: var(--space-xxl);
  }
  .commitment-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-base);
  }
  .commitment-icon {
    width: 44px;
    height: 44px;
    background: var(--primary);
    color: var(--on-primary);
    border-radius: var(--rounded-full);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .commitment-card h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: var(--space-xs);
  }
  .commitment-card p {
    color: var(--body);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .sustainability-closing {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }
  .sustainability-closing p {
    font-size: 1.05rem;
    color: var(--body);
    line-height: 1.7;
  }
  @media (min-width: 768px) {
    .hero-content h1 { font-size: 3.25rem; }
    .commitments-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
