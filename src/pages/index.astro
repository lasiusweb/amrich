---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';
import Features from '../components/Features.astro';
import Stats from '../components/Stats.astro';
import Testimonials from '../components/Testimonials.astro';
import Newsletter from '../components/Newsletter.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';
import { productCategories, site } from '../data/site.ts';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": site.name,
      "url": site.url,
      "description": site.description,
      "contactPoint": {
        "@type": "ContactPoint",
        "email": site.email,
        "contactType": "customer service",
      },
      "sameAs": [
        "https://www.facebook.com/amrichaquaculture",
        "https://www.linkedin.com/company/amrich-aquaculture",
        "https://www.youtube.com/@amrichaquaculture",
      ],
    },
    {
      "@type": "WebSite",
      "name": site.name,
      "url": site.url,
    },
  ],
};
---

<BaseLayout
  title="AMRich Aquaculture Solutions | Premium Fish & Shrimp Farm Products"
  description="Premium aquaculture products for healthier farms and better yields. Scientifically formulated solutions for disease management, water quality, probiotics, and feed supplements."
  schema={schema}
>
  <Header />

  <main class="flex-1">
    <!-- Hero -->
    <Hero />

    <!-- Stats -->
    <Stats />

    <!-- Products Section -->
    <section class="section-padding bg-gray-50">
      <div class="container-wide">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-extrabold text-primary-800 mb-4">
            Our Product Range
          </h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Comprehensive solutions for every aspect of aquaculture management.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {productCategories.map((product) => (
            <ProductCard
              title={product.name}
              description={product.description}
              href={product.href}
              icon={product.icon}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Features -->
    <Features />

    <!-- Testimonials -->
    <Testimonials />

    <!-- CTA Banner -->
    <CTABanner />

    <!-- Newsletter -->
    <Newsletter />
  </main>

  <Footer />
</BaseLayout>
