---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABanner from '../../components/CTABanner.astro';
import Footer from '../../components/Footer.astro';
import { site } from '../../data/site.ts';
import { categories } from '../../data/products.ts';
import { getIcon } from '../../data/icons.ts';

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "All Products | Amrich Pharma",
  "description": "Browse our complete range of aquaculture products for shrimp and fish farming — probiotics, disease control, feed supplements, and water quality solutions.",
  "url": `${site.url}/products/`,
  "isPartOf": {
    "@type": "WebSite",
    "name": site.name,
    "url": site.url,
  },
};
---

<BaseLayout
  title="All Products | Amrich Pharma"
  description="Browse our complete range of aquaculture products for shrimp and fish farming — probiotics, disease control, feed supplements, and water quality solutions."
  schema={schema}
>
  <Header />

  <main id="main-content" class="flex-1">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Products' },
    ]} />

    <section class="bg-gradient-to-br from-brand-900 via-brand-800 to-ocean-900 text-white py-20">
      <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">
            Our Product Range
          </h1>
          <p class="text-lg text-white/70 leading-relaxed">
            Comprehensive solutions for every aspect of aquaculture management. Explore our four specialized product categories.
          </p>
        </div>
      </div>
    </section>

    <section class="section-padding">
      <div class="container-wide">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {categories.map((cat) => (
            <a
              href={`/products/${cat.slug}/`}
              class="group block bg-surface border border-border rounded-2xl hover:border-brand-200 hover:shadow-lg hover:shadow-brand-500/5 transition-all duration-300 overflow-hidden"
            >
              <div class="p-8 flex flex-col sm:flex-row gap-6 items-start">
                <div class="size-16 rounded-2xl bg-gradient-to-br from-brand-50 to-ocean-50 dark:from-brand-900/20 dark:to-ocean-900/20 flex items-center justify-center p-3.5 shrink-0">
                  <span class="text-brand-600" set:html={getIcon(cat.icon)} />
                </div>
                <div>
                  <h2 class="text-xl font-bold text-ink mb-2 group-hover:text-brand-600 transition-colors">{cat.name}</h2>
                  <p class="text-sm text-ink-light leading-relaxed">{cat.description}</p>
                  <div class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 group-hover:text-brand-700 transition-colors">
                    View Products
                    <span class="size-4 group-hover:translate-x-0.5 transition-transform" set:html={getIcon('arrow')} />
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTABanner />
  </main>

  <Footer />
</BaseLayout>
