---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABanner from '../../components/CTABanner.astro';
import Footer from '../../components/Footer.astro';
import { site } from '../../data/site.ts';
import { categories } from '../../data/products.ts';

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "All Products | AMRich Aquaculture",
  "description": "Browse our complete range of aquaculture products across disease management, feed supplements, probiotics, and water quality solutions.",
  "url": `${site.url}/products/`,
  "isPartOf": {
    "@type": "WebSite",
    "name": site.name,
    "url": site.url,
  },
};
---

<BaseLayout
  title="All Products | AMRich Aquaculture"
  description="Browse our complete range of aquaculture products across disease management, feed supplements, probiotics, and water quality solutions."
  schema={schema}
>
  <Header />

  <main class="flex-1">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Products' },
    ]} />

    <!-- Hero -->
    <section class="bg-gradient-to-br from-primary-800 to-primary-900 text-white py-16">
      <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
            Our Product Range
          </h1>
          <p class="text-lg text-gray-300 leading-relaxed">
            Comprehensive solutions for every aspect of aquaculture management. Explore our four specialized product categories.
          </p>
        </div>
      </div>
    </section>

    <!-- Product Categories -->
    <section class="section-padding">
      <div class="container-wide">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {categories.map((cat) => (
            <a
              href={`/products/${cat.slug}/`}
              class="group block bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg hover:border-primary-300 transition-all duration-300 overflow-hidden"
            >
              <div class={`bg-gradient-to-br ${cat.gradient} p-6`}>
                <div class="text-4xl mb-2">{cat.icon}</div>
                <h2 class="text-xl font-bold text-white mb-2">{cat.name}</h2>
                <p class="text-white/80 text-sm">{cat.description}</p>
              </div>
              <div class="p-6">
                <div class="flex items-center text-sm font-semibold text-primary-800 group-hover:text-primary-600 transition-colors">
                  View Products
                  <svg class="ml-1 w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <CTABanner />
  </main>

  <Footer />
</BaseLayout>
