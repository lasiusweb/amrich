---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import CTABanner from '../../../components/CTABanner.astro';
import Footer from '../../../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Feed & Pond Preparers Products",
  "description": "Premium feed supplements and pond preparation products to optimize growth conditions and nutritional intake for aquaculture.",
  "url": "https://amrich.netlify.app/products/feed-pond-preparers/",
  "isPartOf": {
    "@type": "WebSite",
    "name": "AMRich Aquaculture",
    "url": "https://amrich.netlify.app"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How often should I apply pond preparers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We recommend applying pond preparers 7-14 days before stocking. This allows sufficient time for the beneficial microorganisms to establish and create optimal conditions."
      }
    },
    {
      "@type": "Question",
      "name": "What is the best feed supplement for faster growth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our Growth-Boost formula contains essential amino acids and vitamins that accelerate growth rates. Combined with our probiotics for better feed conversion ratios."
      }
    },
    {
      "@type": "Question",
      "name": "Can feed supplements replace regular feed?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, our feed supplements are designed to enhance the nutritional value of your regular feed, not replace it. They work best when used as part of a comprehensive feeding program."
      }
    }
  ]
};
---

<BaseLayout
  title="Feed & Pond Preparers Products | AMRich Aquaculture"
  description="Premium feed supplements and pond preparation products to optimize growth conditions and nutritional intake for aquaculture operations."
  schema={schema}
>
  <Header />

  <main class="flex-1">
    <!-- Hero -->
    <section class="bg-gradient-to-br from-forest-800 to-forest-900 text-white py-16">
      <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-white/10 text-sm font-medium text-aqua-300 mb-4">
            🐟 Feed & Pond Preparers
          </div>
          <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
            Optimize Growth
          </h1>
          <p class="text-lg text-gray-300 leading-relaxed">
            Premium feed supplements and pond preparation products designed to maximize growth rates and nutritional efficiency in your aquaculture operations.
          </p>
        </div>
      </div>
    </section>

    <!-- Products -->
    <section class="section-padding">
      <div class="container-wide">
        <h2 class="text-3xl font-extrabold text-primary-800 mb-8">Our Solutions</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <div class="text-3xl mb-3">📈</div>
            <h3 class="text-xl font-bold text-primary-800 mb-2">Growth-Boost Formula</h3>
            <p class="text-gray-600 text-sm mb-4">
              High-performance feed supplement enriched with essential amino acids, vitamins, and minerals to accelerate growth rates.
            </p>
            <ul class="text-sm text-gray-500 space-y-1">
              <li>✓ 30% faster growth</li>
              <li>✓ Improved FCR</li>
              <li>✓ Enhanced color</li>
            </ul>
          </div>

          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <div class="text-3xl mb-3">🌱</div>
            <h3 class="text-xl font-bold text-primary-800 mb-2">Pond Prep Elite</h3>
            <p class="text-gray-600 text-sm mb-4">
              Complete pond preparation solution that establishes beneficial microorganism populations before stocking.
            </p>
            <ul class="text-sm text-gray-500 space-y-1">
              <li>✓ Rapid colonization</li>
              <li>✓ Pathogen suppression</li>
              <li>✓ pH stabilization</li>
            </ul>
          </div>

          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <div class="text-3xl mb-3">🧫</div>
            <h3 class="text-xl font-bold text-primary-800 mb-2">Feed Enzyme Plus</h3>
            <p class="text-gray-600 text-sm mb-4">
              Digestive enzyme supplement that improves nutrient absorption and reduces feed waste in aquaculture systems.
            </p>
            <ul class="text-sm text-gray-500 space-y-1">
              <li>✓ Better digestion</li>
              <li>✓ Less waste</li>
              <li>✓ Cost effective</li>
            </ul>
          </div>

          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <div class="text-3xl mb-3">🐟</div>
            <h3 class="text-xl font-bold text-primary-800 mb-2">Starter Feed Premix</h3>
            <p class="text-gray-600 text-sm mb-4">
              Specialized nutrition package for larval and juvenile stages to ensure strong start and high survival rates.
            </p>
            <ul class="text-sm text-gray-500 space-y-1">
              <li>✓ Larval nutrition</li>
              <li>✓ High survival</li>
              <li>✓ Easy application</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-padding bg-gray-50">
      <div class="container-wide max-w-3xl">
        <h2 class="text-3xl font-extrabold text-primary-800 mb-8">Frequently Asked Questions</h2>

        <div class="space-y-6">
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="text-lg font-bold text-primary-800 mb-2">How often should I apply pond preparers?</h3>
            <p class="text-gray-600 text-sm">
              We recommend applying pond preparers 7-14 days before stocking. This allows sufficient time for the beneficial microorganisms to establish and create optimal conditions.
            </p>
          </div>

          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="text-lg font-bold text-primary-800 mb-2">What is the best feed supplement for faster growth?</h3>
            <p class="text-gray-600 text-sm">
              Our Growth-Boost formula contains essential amino acids and vitamins that accelerate growth rates. Combined with our probiotics for better feed conversion ratios.
            </p>
          </div>

          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="text-lg font-bold text-primary-800 mb-2">Can feed supplements replace regular feed?</h3>
            <p class="text-gray-600 text-sm">
              No, our feed supplements are designed to enhance the nutritional value of your regular feed, not replace it. They work best when used as part of a comprehensive feeding program.
            </p>
          </div>
        </div>
      </div>
    </section>

    <CTABanner />
  </main>

  <Footer />
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
