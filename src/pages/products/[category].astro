---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Icon from '../../components/icons/Icon.astro';
import ProductImage from '../../components/ProductImage.astro';
import products, { getProductsByCategory, getCategory, getAllCategories } from '../../data/products';

export async function getStaticPaths() {
  return getAllCategories().map(cat => ({
    params: { category: cat.slug },
    props: { categorySlug: cat.slug },
  }));
}

const { categorySlug } = Astro.props as { categorySlug: string };
const category = getCategory(categorySlug);
const catProducts = getProductsByCategory(categorySlug);
---

<Layout
  title={`${category.name} | Amrich Pharma`}
  description={category.desc}
>
  <div class="category-page container">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Products', href: '/products' },
      { label: category.name },
    ]} />

    <h1>{category.name}</h1>
    <p class="category-desc">{category.desc}</p>

    <div class="product-grid">
      {catProducts.map(p => (
        <a href={`/products/${categorySlug}/${p.slug}`} class="product-card card">
          <ProductImage slug={p.slug} name={p.name} width={400} height={250} class="card-img" />
          <div class="card-body">
            <h2>{p.name}</h2>
            <p class="product-tagline">{p.tagline}</p>
            <span class="product-meta"><Icon name="brochure" size={14} /> {p.form}</span>
            <div class="product-badges">
              {p.badges.map(b => <span class="mini-badge">{b}</span>)}
            </div>
            <span class="card-cta">View Details <Icon name="arrow-right" size={14} /></span>
          </div>
        </a>
      ))}
    </div>

    <div class="category-cta hero-band-dark section-padding" style="border-radius: var(--rounded-xl); margin-top: var(--space-xxl);">
      <div class="cta-content">
        <Icon name="farmer" size={48} style="margin-bottom: var(--space-sm); opacity: 0.8;" />
        <h2>Need Help Choosing?</h2>
        <p>Our aquaculture specialists can recommend the right product for your pond conditions, species, and farm size.</p>
        <button class="btn-primary" data-modal="quote-form" data-product={category.name}>Get a Recommendation</button>
      </div>
    </div>
  </div>
</Layout>

<style>
  .category-page {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xxl);
  }
  h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: var(--space-sm);
    letter-spacing: -0.5px;
  }
  .category-desc {
    font-size: 1.05rem;
    color: var(--body);
    margin-bottom: var(--space-xl);
    max-width: 700px;
    line-height: 1.6;
  }
  .product-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  .product-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    overflow: hidden;
    padding: 0;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .product-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }
  .card-img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }
  .card-body {
    padding: var(--space-base) var(--space-lg) var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }
  .product-card h2 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--ink);
  }
  .product-tagline {
    font-size: 0.9rem;
    color: var(--primary);
    font-weight: 500;
  }
  .product-meta {
    font-size: 0.85rem;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .product-badges {
    display: flex;
    gap: var(--space-xxs);
    flex-wrap: wrap;
  }
  .mini-badge {
    font-size: 11px;
    background: var(--surface-strong);
    color: var(--ink);
    padding: 2px 8px;
    border-radius: var(--rounded-pill);
    font-weight: 500;
  }
  .card-cta {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--primary);
    margin-top: auto;
    padding-top: var(--space-sm);
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  .cta-content h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--on-dark);
    margin-bottom: var(--space-sm);
  }
  .cta-content p {
    color: var(--on-dark-soft);
    margin-bottom: var(--space-lg);
  }
  @media (min-width: 768px) {
    .product-grid { grid-template-columns: 1fr 1fr; }
    h1 { font-size: 2.5rem; }
    .card-img { height: 220px; }
  }
</style>
