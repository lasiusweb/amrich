---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import CTABanner from '../../../components/CTABanner.astro';
import Footer from '../../../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Water Quality & Ammonia Control Products",
  "description": "Professional-grade water treatment products to maintain optimal water quality and control ammonia levels in aquaculture.",
  "url": "https://amrich.netlify.app/products/water-quality-ammonia-control/",
  "isPartOf": {
    "@type": "WebSite",
    "name": "AMRich Aquaculture",
    "url": "https://amrich.netlify.app"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the ideal ammonia level for shrimp farming?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For optimal shrimp health, maintain ammonia levels below 0.5 ppm. Our ammonia control products help reduce toxic ammonia to safe levels quickly and maintain them throughout the production cycle."
      }
    },
    {
      "@type": "Question",
      "name": "How often should I test water quality?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We recommend daily testing during the first 2 weeks after stocking, then every 2-3 days during grow-out. Critical parameters include ammonia, nitrite, pH, dissolved oxygen, and alkalinity."
      }
    },
    {
      "@type": "Question",
      "name": "Can water quality products be used in biofloc systems?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, our water quality products are compatible with biofloc technology. In fact, they help maintain the delicate balance needed for successful biofloc systems by controlling ammonia without disrupting beneficial bacteria."
      }
    }
  ]
};
---

<BaseLayout
  title="Water Quality & Ammonia Control Products | AMRich Aquaculture"
  description="Professional-grade water treatment products to maintain optimal water quality and control ammonia levels in aquaculture operations."
  schema={schema}
>
  <Header />

  <main class="flex-1">
    <!-- Hero -->
    <section class="bg-gradient-to-br from-blue-600 to-blue-800 text-white py-16">
      <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-white/10 text-sm font-medium text-white mb-4">
            💧 Water Quality & Ammonia Control
          </div>
          <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
            Crystal Clear Water
          </h1>
          <p class="text-lg text-gray-100 leading-relaxed">
            Professional-grade water treatment solutions that maintain optimal quality parameters and control ammonia for healthy, productive aquaculture systems.
          </p>
        </div>
      </div>
    </section>

    <!-- Products -->
    <section class="section-padding">
      <div class="container-wide">
        <h2 class="text-3xl font-extrabold text-primary-800 mb-8">Our Solutions</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <div class="text-3xl mb-3">⚗️</div>
            <h3 class="text-xl font-bold text-primary-800 mb-2">AmmoniClear Pro</h3>
            <p class="text-gray-600 text-sm mb-4">
              Fast-acting ammonia neutralizer that converts toxic ammonia to harmless compounds within hours of application.
            </p>
            <ul class="text-sm text-gray-500 space-y-1">
              <li>✓ Works in 4-6 hours</li>
              <li>✓ Long lasting effect</li>
              <li>✓ Safe for all species</li>
            </ul>
          </div>

          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <div class="text-3xl mb-3">🫧</div>
            <h3 class="text-xl font-bold text-primary-800 mb-2">OxyBoost</h3>
            <p class="text-gray-600 text-sm mb-4">
              Dissolved oxygen enhancer that increases oxygen levels and improves water clarity for healthier aquatic environments.
            </p>
            <ul class="text-sm text-gray-500 space-y-1">
              <li>✓ Rapid oxygen release</li>
              <li>✓ Clarifies water</li>
              <li>✓ Emergency use safe</li>
            </ul>
          </div>

          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <div class="text-3xl mb-3">🧪</div>
            <h3 class="text-xl font-bold text-primary-800 mb-2">pH Balance Plus</h3>
            <p class="text-gray-600 text-sm mb-4">
              pH stabilization system that maintains optimal alkalinity and prevents dangerous pH swings in aquaculture ponds.
            </p>
            <ul class="text-sm text-gray-500 space-y-1">
              <li>✓ Buffers pH</li>
              <li>✓ Alkalinity boost</li>
              <li>✓ Slow release</li>
            </ul>
          </div>

          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <div class="text-3xl mb-3">🔮</div>
            <h3 class="text-xl font-bold text-primary-800 mb-2">ClarityMax</h3>
            <p class="text-gray-600 text-sm mb-4">
              Water clarifier that removes suspended particles, reduces turbidity, and improves light penetration for healthier ponds.
            </p>
            <ul class="text-sm text-gray-500 space-y-1">
              <li>✓ Flocculation</li>
              <li>✓ UV protection</li>
              <li>✓ Algae control</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-padding bg-gray-50">
      <div class="container-wide max-w-3xl">
        <h2 class="text-3xl font-extrabold text-primary-800 mb-8">Frequently Asked Questions</h2>

        <div class="space-y-6">
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="text-lg font-bold text-primary-800 mb-2">What is the ideal ammonia level for shrimp farming?</h3>
            <p class="text-gray-600 text-sm">
              For optimal shrimp health, maintain ammonia levels below 0.5 ppm. Our ammonia control products help reduce toxic ammonia to safe levels quickly and maintain them throughout the production cycle.
            </p>
          </div>

          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="text-lg font-bold text-primary-800 mb-2">How often should I test water quality?</h3>
            <p class="text-gray-600 text-sm">
              We recommend daily testing during the first 2 weeks after stocking, then every 2-3 days during grow-out. Critical parameters include ammonia, nitrite, pH, dissolved oxygen, and alkalinity.
            </p>
          </div>

          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="text-lg font-bold text-primary-800 mb-2">Can water quality products be used in biofloc systems?</h3>
            <p class="text-gray-600 text-sm">
              Yes, our water quality products are compatible with biofloc technology. In fact, they help maintain the delicate balance needed for successful biofloc systems by controlling ammonia without disrupting beneficial bacteria.
            </p>
          </div>
        </div>
      </div>
    </section>

    <CTABanner />
  </main>

  <Footer />
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
