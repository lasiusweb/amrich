---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import FAQSection from '../../../../components/FAQSection.astro';
import CTABanner from '../../../../components/CTABanner.astro';
import Footer from '../../../../components/Footer.astro';
import StickyCTA from '../../../../components/StickyCTA.astro';
import QuoteModal from '../../../../components/QuoteModal.astro';
import { categories } from '../../../../data/products.ts';
import { site } from '../../../../data/site.ts';
import { getIcon } from '../../../../data/icons.ts';

export function getStaticPaths() {
  const paths: { params: { category: string; product: string }; props: { category: typeof categories[0]; product: typeof categories[0]['products'][0] } }[] = [];

  for (const category of categories) {
    for (const product of category.products) {
      paths.push({
        params: { category: category.slug, product: product.slug },
        props: { category, product },
      });
    }
  }

  return paths;
}

const { category, product } = Astro.props;

const metaDescription = `${product.name} — ${product.tagline} ${product.shortDescription}`;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      "name": product.name,
      "description": product.shortDescription,
      "url": `${site.url}/products/${category.slug}/${product.slug}/`,
      "brand": {
        "@type": "Organization",
        "name": site.name,
      },
      "category": category.name,
      ...(product.specs ? {
        "additionalProperty": product.specs.map(s => ({
          "@type": "PropertyValue",
          "name": s.label,
          "value": s.value,
        })),
      } : {}),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": "Products", "item": `${site.url}/products/` },
        { "@type": "ListItem", "position": 3, "name": category.name, "item": `${site.url}/products/${category.slug}/` },
        { "@type": "ListItem", "position": 4, "name": product.name },
      ],
    },
  ],
};

const relatedProducts = category.products.filter((p) => p.slug !== product.slug).slice(0, 3);
---

<BaseLayout
  title={`${product.name} | ${site.name}`}
  description={metaDescription}
  schema={schema}
>
  <Header />

  <main id="main-content" class="flex-1">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Products', href: '/products/' },
      { label: category.name, href: `/products/${category.slug}/` },
      { label: product.name },
    ]} />

    <section class="bg-gradient-to-br from-brand-900 via-brand-800 to-ocean-900 text-white py-20">
      <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8">
          <div class="max-w-4xl">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 text-sm font-medium text-brand-300 mb-4">
              <span class="size-4" set:html={getIcon(category.icon)} />
              <span>{category.name}</span>
            </div>
            <div class="size-16 rounded-2xl bg-white/10 backdrop-blur-sm flex items-center justify-center p-3 mb-4">
              <span set:html={getIcon(product.icon)} />
            </div>
            <h1 class="font-display text-4xl md:text-5xl font-bold mb-2">
              {product.name}
            </h1>
            <p class="text-xl text-brand-300 font-medium mb-4">
              {product.tagline}
            </p>
            <p class="text-lg text-white/70 leading-relaxed max-w-2xl">
              {product.shortDescription}
            </p>
          </div>
          {product.image && (
            <div class="shrink-0">
              <img
                src={product.image}
                alt={`${product.name} product illustration`}
                class="w-64 h-64 md:w-72 md:h-72 object-contain drop-shadow-xl"
                loading="eager"
              />
            </div>
          )}
        </div>
      </div>
    </section>

    <section class="section-padding pb-0">
      <div class="container-wide max-w-5xl">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
          <div class="lg:col-span-2 space-y-12">

            <div>
              <h2 class="font-display text-2xl font-bold text-ink mb-4">About This Product</h2>
              <p class="text-ink-light leading-relaxed">{product.description}</p>
            </div>

            <div>
              <h2 class="font-display text-2xl font-bold text-ink mb-6">Why Farmers Use {product.name}</h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {product.benefits.map((benefit) => (
                  <div class="flex items-start gap-3 bg-surface-muted rounded-xl p-4 border border-border">
                    <span class="mt-0.5 shrink-0 text-brand-500" set:html={getIcon('check')} />
                    <span class="text-sm text-ink leading-relaxed">{benefit}</span>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <h2 class="font-display text-2xl font-bold text-ink mb-6">How to Apply</h2>
              <div class="bg-brand-50 dark:bg-brand-900/10 border border-brand-100 dark:border-brand-800/30 rounded-2xl p-6 md:p-8">
                <div class="space-y-5">
                  {product.applicationSteps.map((step, i) => (
                    <div class="flex gap-4">
                      <div class="size-8 rounded-full bg-brand-600 dark:bg-brand-500 text-white text-sm font-bold flex items-center justify-center shrink-0 mt-0.5">
                        {i + 1}
                      </div>
                      <p class="text-ink leading-relaxed pt-1">{step}</p>
                    </div>
                  ))}
                </div>
              </div>
              <div class="mt-4 flex items-start gap-3 bg-amber-50 dark:bg-amber-900/10 border border-amber-200 dark:border-amber-800/30 rounded-xl p-4">
                <svg class="size-5 text-amber-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                </svg>
                <div>
                  <span class="text-sm font-bold text-amber-800 dark:text-amber-300">Farmer Tip:</span>
                  <span class="text-sm text-amber-700 dark:text-amber-400/90"> {product.farmerTip}</span>
                </div>
              </div>
            </div>

            {product.stockingDensityGuide && product.stockingDensityGuide.length > 0 && (
              <div>
                <h2 class="font-display text-2xl font-bold text-ink mb-6">Stocking Density Guide</h2>
                <div class="overflow-x-auto rounded-xl border border-border">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="bg-brand-50 dark:bg-brand-900/20">
                        <th class="text-left px-5 py-3 font-semibold text-ink">Stocking Density</th>
                        <th class="text-left px-5 py-3 font-semibold text-ink">Dosage</th>
                      </tr>
                    </thead>
                    <tbody>
                      {product.stockingDensityGuide.map((row) => (
                        <tr class="border-t border-border">
                          <td class="px-5 py-3 text-ink">{row.density}</td>
                          <td class="px-5 py-3 text-ink font-medium">{row.dosage}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            {product.dosageTiers && product.dosageTiers.length > 0 && (
              <div>
                <h2 class="font-display text-2xl font-bold text-ink mb-6">Dosage Tiers</h2>
                <div class="overflow-x-auto rounded-xl border border-border">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="bg-brand-50 dark:bg-brand-900/20">
                        <th class="text-left px-5 py-3 font-semibold text-ink">Pond Condition</th>
                        <th class="text-left px-5 py-3 font-semibold text-ink">Dosage</th>
                      </tr>
                    </thead>
                    <tbody>
                      {product.dosageTiers.map((tier) => (
                        <tr class="border-t border-border">
                          <td class="px-5 py-3 text-ink">{tier.label}</td>
                          <td class="px-5 py-3 text-ink font-medium">{tier.value}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            {product.resources.length > 0 && (
              <div>
                <h2 class="font-display text-2xl font-bold text-ink mb-6">Resources</h2>
                <div class="flex flex-wrap gap-3">
                  {product.resources.map((resource) => (
                    <a
                      href={resource.href}
                      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-surface border border-border text-sm font-semibold text-ink hover:border-brand-200 hover:text-brand-600 hover:shadow-sm transition-all duration-200 focus-ring"
                    >
                      <span class="text-brand-500" set:html={getIcon('download')} />
                      {resource.label}
                    </a>
                  ))}
                </div>
              </div>
            )}

          </div>

          <div class="space-y-6">
            <div class="bg-surface border border-border rounded-2xl p-6 shadow-sm sticky top-24">
              <h3 class="font-display text-lg font-bold text-ink mb-4">Quick Specs</h3>
              <div class="space-y-4">
                <div class="pb-4 border-b border-border">
                  <span class="text-xs font-semibold text-ink-light/60 uppercase tracking-wider">Form</span>
                  <p class="text-ink font-medium mt-1 text-sm">{product.form}</p>
                </div>

                <div class="pb-4 border-b border-border">
                  <span class="text-xs font-semibold text-ink-light/60 uppercase tracking-wider">Dosage</span>
                  <p class="text-ink font-medium mt-1 text-sm">{product.dosage}</p>
                </div>

                <div class="pb-4 border-b border-border">
                  <span class="text-xs font-semibold text-ink-light/60 uppercase tracking-wider">Pack Size</span>
                  <p class="text-ink font-medium mt-1 text-sm">{product.packSize}</p>
                </div>

                <div class="pb-4 border-b border-border">
                  <span class="text-xs font-semibold text-ink-light/60 uppercase tracking-wider">Shelf Life</span>
                  <p class="text-ink font-medium mt-1 text-sm">{product.shelfLife}</p>
                </div>

                {product.specs && product.specs.map((spec) => (
                  <div class="pb-4 border-b border-border">
                    <span class="text-xs font-semibold text-ink-light/60 uppercase tracking-wider">{spec.label}</span>
                    <p class="text-ink font-medium mt-1 text-sm">{spec.value}</p>
                  </div>
                ))}

                <div class="pb-4 border-b border-border">
                  <span class="text-xs font-semibold text-ink-light/60 uppercase tracking-wider">Target Species</span>
                  <div class="flex flex-wrap gap-2 mt-2">
                    {product.targetSpecies.map((species) => (
                      <span class="inline-flex items-center px-3 py-1 rounded-full bg-brand-50 dark:bg-brand-900/20 text-brand-700 dark:text-brand-300 text-xs font-medium">
                        {species}
                      </span>
                    ))}
                  </div>
                </div>

                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-50 dark:bg-brand-900/20 text-brand-700 dark:text-brand-300 text-xs font-medium">
                  <span class="text-brand-500" set:html={getIcon('iso')} />
                  ISO 9001:2015 Certified
                </div>
              </div>
            </div>

            {product.testimonial && (
              <div class="bg-surface-muted border border-border rounded-2xl p-6">
                <span class="text-brand-500 mb-3 block" set:html={getIcon('quote')} />
                <blockquote class="text-sm text-ink-light leading-relaxed mb-4 italic">
                  &ldquo;{product.testimonial.quote}&rdquo;
                </blockquote>
                <div class="flex items-center justify-between">
                  <div>
                    <div class="text-sm font-semibold text-ink">{product.testimonial.name}</div>
                    <div class="text-xs text-ink-light/70">{product.testimonial.location}</div>
                  </div>
                  {product.testimonial.metric && (
                    <span class="text-xs font-bold text-brand-600 bg-brand-50 dark:bg-brand-900/20 px-2.5 py-1 rounded-full">
                      {product.testimonial.metric}
                    </span>
                  )}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    {product.faqs.length > 0 && (
      <FAQSection items={product.faqs} />
    )}

    {relatedProducts.length > 0 && (
      <section class="section-padding bg-surface-muted border-t border-border">
        <div class="container-wide">
          <h2 class="font-display text-2xl md:text-3xl font-bold text-ink mb-8">Related Products</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {relatedProducts.map((rp) => (
              <a
                href={`/products/${category.slug}/${rp.slug}/`}
                class="group block bg-surface border border-border rounded-2xl p-6 hover:border-brand-200 hover:shadow-lg hover:shadow-brand-500/5 transition-all duration-300"
              >
                <div class="flex items-center gap-3 mb-3">
                  <div class="size-10 rounded-xl bg-brand-50 dark:bg-brand-900/20 flex items-center justify-center p-2 group-hover:scale-110 transition-transform duration-300">
                    <span class="text-brand-600" set:html={getIcon(rp.icon)} />
                  </div>
                </div>
                <h3 class="text-lg font-bold text-ink mb-1 group-hover:text-brand-600 transition-colors">
                  {rp.name}
                </h3>
                <p class="text-sm text-ink-light leading-relaxed mb-4">
                  {rp.shortDescription}
                </p>
                <div class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 group-hover:text-brand-700 transition-colors">
                  View Details
                  <span class="size-4 group-hover:translate-x-0.5 transition-transform" set:html={getIcon('arrow')} />
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <CTABanner
      heading="Ready to Improve Your Pond?"
      description="Get personalized product recommendations and dosing plans from our aquaculture experts."
      ctaLabel="Get a Quote"
      ctaHref="#quote-modal"
    />
  </main>

  <Footer />
  <StickyCTA productName={product.name} categoryName={category.name} />
  <QuoteModal />
</BaseLayout>
