---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import CTABanner from '../../../components/CTABanner.astro';
import Footer from '../../../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Disease & Stress Management Products",
  "description": "Advanced treatments and preventive solutions to protect aquaculture stock from common diseases and environmental stress.",
  "url": "https://amrich.netlify.app/products/disease-stress-management/",
  "isPartOf": {
    "@type": "WebSite",
    "name": "AMRich Aquaculture",
    "url": "https://amrich.netlify.app"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are the most common diseases in shrimp farming?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most common diseases include White Spot Syndrome Virus (WSSV), Early Mortality Syndrome (EMS), and Vibrio infections. Our products target these specific pathogens with proven formulations."
      }
    },
    {
      "@type": "Question",
      "name": "How do AMRich disease prevention products work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our products use a combination of immune stimulants, antimicrobial agents, and stress-reducing compounds to strengthen fish and shrimp natural defenses against common aquaculture pathogens."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use disease management products with probiotics?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, our disease management products are designed to work synergistically with our probiotic range. We recommend consulting our technical team for an integrated treatment plan."
      }
    }
  ]
};
---

<BaseLayout
  title="Disease & Stress Management Products | AMRich Aquaculture"
  description="Advanced treatments and preventive solutions to protect your aquaculture stock from common diseases including WSSV, EMS, and Vibrio infections."
  schema={schema}
>
  <Header />

  <main class="flex-1">
    <!-- Hero -->
    <section class="bg-gradient-to-br from-primary-800 to-primary-900 text-white py-16">
      <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-white/10 text-sm font-medium text-aqua-300 mb-4">
            🛡️ Disease & Stress Management
          </div>
          <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
            Protect Your Stock
          </h1>
          <p class="text-lg text-gray-300 leading-relaxed">
            Advanced treatments and preventive solutions to safeguard your aquaculture operations against disease outbreaks and environmental stress.
          </p>
        </div>
      </div>
    </section>

    <!-- Products -->
    <section class="section-padding">
      <div class="container-wide">
        <h2 class="text-3xl font-extrabold text-primary-800 mb-8">Our Solutions</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Product 1 -->
          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <div class="text-3xl mb-3">💊</div>
            <h3 class="text-xl font-bold text-primary-800 mb-2">Immuno-Boost Pro</h3>
            <p class="text-gray-600 text-sm mb-4">
              Advanced immune system stimulant that enhances natural defense mechanisms in fish and shrimp. Ideal for pre-emptive disease prevention.
            </p>
            <ul class="text-sm text-gray-500 space-y-1">
              <li>✓ Enhances immune response</li>
              <li>✓ Safe for all species</li>
              <li>✓ No withdrawal period</li>
            </ul>
          </div>

          <!-- Product 2 -->
          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <div class="text-3xl mb-3">🧬</div>
            <h3 class="text-xl font-bold text-primary-800 mb-2">Vibrio Shield</h3>
            <p class="text-gray-600 text-sm mb-4">
              Targeted antimicrobial solution specifically formulated to combat Vibrio bacteria infections in aquaculture environments.
            </p>
            <ul class="text-sm text-gray-500 space-y-1">
              <li>✓ Broad-spectrum activity</li>
              <li>✓ Environmentally safe</li>
              <li>✓ Fast-acting formula</li>
            </ul>
          </div>

          <!-- Product 3 -->
          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <div class="text-3xl mb-3">🌿</div>
            <h3 class="text-xl font-bold text-primary-800 mb-2">Stress-Away Plus</h3>
            <p class="text-gray-600 text-sm mb-4">
              Natural stress-reducing compound that helps aquatic species cope with environmental changes, handling, and transport stress.
            </p>
            <ul class="text-sm text-gray-500 space-y-1">
              <li>✓ Reduces cortisol levels</li>
              <li>✓ Plant-based formula</li>
              <li>✓ Improves survival rates</li>
            </ul>
          </div>

          <!-- Product 4 -->
          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <div class="text-3xl mb-3">🔬</div>
            <h3 class="text-xl font-bold text-primary-800 mb-2">WSSV Prevention Kit</h3>
            <p class="text-gray-600 text-sm mb-4">
              Comprehensive prevention package designed to protect shrimp farms from White Spot Syndrome Virus outbreaks.
            </p>
            <ul class="text-sm text-gray-500 space-y-1">
              <li>✓ Complete prevention system</li>
              <li>✓ Field-tested formula</li>
              <li>✓ Includes monitoring tools</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="section-padding bg-gray-50">
      <div class="container-wide max-w-3xl">
        <h2 class="text-3xl font-extrabold text-primary-800 mb-8">Frequently Asked Questions</h2>

        <div class="space-y-6">
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="text-lg font-bold text-primary-800 mb-2">What are the most common diseases in shrimp farming?</h3>
            <p class="text-gray-600 text-sm">
              The most common diseases include White Spot Syndrome Virus (WSSV), Early Mortality Syndrome (EMS), and Vibrio infections. Our products target these specific pathogens with proven formulations.
            </p>
          </div>

          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="text-lg font-bold text-primary-800 mb-2">How do AMRich disease prevention products work?</h3>
            <p class="text-gray-600 text-sm">
              Our products use a combination of immune stimulants, antimicrobial agents, and stress-reducing compounds to strengthen fish and shrimp natural defenses against common aquaculture pathogens.
            </p>
          </div>

          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="text-lg font-bold text-primary-800 mb-2">Can I use disease management products with probiotics?</h3>
            <p class="text-gray-600 text-sm">
              Yes, our disease management products are designed to work synergistically with our probiotic range. We recommend consulting our technical team for an integrated treatment plan.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <CTABanner />
  </main>

  <Footer />
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
