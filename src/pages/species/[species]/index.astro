---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQSection from '../../../components/FAQSection.astro';
import CTABanner from '../../../components/CTABanner.astro';
import Footer from '../../../components/Footer.astro';
import { categories } from '../../../data/products.ts';
import { site } from '../../../data/site.ts';
import { getIcon } from '../../../data/icons.ts';

export function getStaticPaths() {
  return [
    { params: { species: 'shrimp' }, props: { species: 'shrimp' } },
    { params: { species: 'fish' }, props: { species: 'fish' } },
  ];
}

const { species } = Astro.props;

const speciesData: Record<string, {
  name: string;
  heroDescription: string;
  metaTitle: string;
  metaDescription: string;
  challenges: string[];
  recommendedProducts: { name: string; slug: string; category: string; reason: string }[];
  faqs: { question: string; answer: string }[];
}> = {
  shrimp: {
    name: 'Shrimp',
    heroDescription: 'Specialized solutions for shrimp farming in coastal India — from hatchery to harvest. Probiotics, disease prevention, and water quality for vannamei and black tiger shrimp.',
    metaTitle: 'Products for Shrimp Farming | Amrich Pharma',
    metaDescription: 'Amrich Pharma products for shrimp farming: probiotics, disease prevention, water quality management, and feed supplements for vannamei and black tiger shrimp.',
    challenges: [
      'Ammonia and nitrite spikes in intensive systems',
      'Blackgill, Browngill, and bacterial infections',
      'Stress from handling, weather changes, and transport',
      'Unstable plankton blooms and water color crashes',
      'Organic load buildup and black soil formation',
    ],
    recommendedProducts: [
      { name: 'FARM PRO', slug: 'farm-pro', category: 'probiotics-soil-care', reason: 'Stabilizes water color and suppresses pathogenic bacteria within 48 hours' },
      { name: 'OXY-FARM', slug: 'oxy-farm', category: 'water-quality-ammonia-control', reason: 'Prevents night-time oxygen crashes and converts toxic nitrites' },
      { name: 'SHRIMP CARE', slug: 'shrimp-care', category: 'disease-stress-management', reason: 'All-in-one health pack for uniform molting and shell hardening' },
      { name: 'GASO CLEAN', slug: 'gaso-clean', category: 'water-quality-ammonia-control', reason: 'Eliminates toxic ammonia and nitrite within 48 hours' },
      { name: 'PRO PLUS', slug: 'pro-plus', category: 'probiotics-soil-care', reason: 'Prevents black soil and boosts DO in shrimp ponds' },
      { name: 'FARMADINE', slug: 'farmadine', category: 'disease-stress-management', reason: 'Controls Blackgill and Browngill in shrimp' },
    ],
    faqs: [
      { question: 'What is the best disease prevention program for shrimp?', answer: 'Use FARM PRO for water column probiotics, SHRIMP CARE for integrated health management, and FARM-C+ before and after stress events. Maintain DO above 4 mg/L and monitor ammonia levels weekly.' },
      { question: 'What stocking density is recommended for vannamei?', answer: 'For traditional ponds: 30–50 PL/m². For higher densities, use PRO PLUS for soil health and OXY-FARM for DO support. Contact our team for a customized protocol.' },
      { question: 'How do I manage water quality in intensive shrimp ponds?', answer: 'Monitor ammonia, nitrite, pH, DO, and alkalinity daily. Use GASO CLEAN for ammonia spikes, OXY-FARM for low oxygen, and W-SOFTENER for pH stability. Regular FARM PRO application supports biological balance.' },
    ],
  },
  fish: {
    name: 'Fish',
    heroDescription: 'Comprehensive solutions for freshwater fish farming. Growth optimization, disease management, and water quality for tilapia, catfish, seabass, and more.',
    metaTitle: 'Products for Fish Farming | Amrich Pharma',
    metaDescription: 'Amrich Pharma products for fish farming: growth supplements, disease prevention, water quality management for tilapia, catfish, seabass, and other species.',
    challenges: [
      'Bacterial infections (Aeromonas) in intensive systems',
      'Poor feed conversion ratios affecting profitability',
      'Ammonia spikes after heavy feeding',
      'Stress from handling and seasonal temperature shifts',
      'Slow growth rates in suboptimal conditions',
    ],
    recommendedProducts: [
      { name: 'GUT-X', slug: 'gut-x', category: 'probiotics-soil-care', reason: 'Improves gut health and reduces FCR through better nutrient absorption' },
      { name: 'FARMADINE', slug: 'farmadine', category: 'disease-stress-management', reason: 'Broad-spectrum disease control for bacterial and fungal infections' },
      { name: 'OMEGA-BOOSTER', slug: 'omega-booster', category: 'feed-pond-preparers', reason: 'Accelerates growth and strengthens immune response' },
      { name: 'GASO CLEAN', slug: 'gaso-clean', category: 'water-quality-ammonia-control', reason: 'Biological ammonia control for high-biomass fish ponds' },
      { name: 'GRO-BIND', slug: 'gro-bind', category: 'feed-pond-preparers', reason: 'Reduces feed waste and improves water stability of pellets' },
      { name: 'FARM-C+', slug: 'farm-c-plus', category: 'disease-stress-management', reason: 'Rapid stress recovery after handling, transport, or weather changes' },
    ],
    faqs: [
      { question: 'How can I improve feed conversion ratio in my fish farm?', answer: 'Use GUT-X for better digestion and GRO-BIND to prevent pellet waste. OMEGA-BOOSTER accelerates metabolic rate. This combined approach typically improves FCR by 15–25%.' },
      { question: 'What are common fish diseases and how do I prevent them?', answer: 'Common diseases include Aeromonas infections and fungal outbreaks. Prevention involves: FARM-C+ for immune support, FARMADINE for disease control, proper water quality management with GASO CLEAN, and regular water testing.' },
      { question: 'What water parameters are critical for fish farming?', answer: 'Maintain temperature (species-dependent), pH 6.5–8.5, DO above 5 mg/L, ammonia below 0.5 ppm, and nitrite below 1 ppm. Test regularly and use GASO CLEAN and W-SOFTENER to maintain optimal ranges.' },
    ],
  },
};

const data = speciesData[species];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "name": data.metaTitle,
      "description": data.metaDescription,
      "url": `${site.url}/species/${species}/`,
    },
    {
      "@type": "FAQPage",
      "mainEntity": data.faqs.map((faq) => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": { "@type": "Answer", "text": faq.answer },
      })),
    },
  ],
};
---

<BaseLayout
  title={data.metaTitle}
  description={data.metaDescription}
  schema={schema}
>
  <Header />

  <main id="main-content" class="flex-1">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Products', href: '/products/' },
      { label: data.name },
    ]} />

    <section class="bg-gradient-to-br from-brand-900 via-brand-800 to-ocean-900 text-white py-20">
      <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <div class="size-14 rounded-2xl bg-white/10 backdrop-blur-sm flex items-center justify-center p-3 mb-4">
            <svg class="size-full text-brand-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              {species === 'shrimp' ? (
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              ) : (
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              )}
            </svg>
          </div>
          <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">
            Products for {data.name} Farming
          </h1>
          <p class="text-lg text-white/70 leading-relaxed">
            {data.heroDescription}
          </p>
        </div>
      </div>
    </section>

    <section class="section-padding">
      <div class="container-wide max-w-4xl">
        <h2 class="font-display text-2xl font-bold text-ink mb-6">Common Challenges in {data.name} Farming</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          {data.challenges.map((challenge) => (
            <div class="flex items-start gap-3 bg-red-50 dark:bg-red-900/10 border border-red-100 dark:border-red-900/20 rounded-xl p-4">
              <svg class="size-5 text-red-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
              </svg>
              <span class="text-sm text-ink">{challenge}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-padding bg-surface-muted border-t border-border">
      <div class="container-wide max-w-4xl">
        <h2 class="font-display text-2xl font-bold text-ink mb-8">Recommended Products</h2>
        <div class="space-y-4">
          {data.recommendedProducts.map((rp) => (
            <a
              href={`/products/${rp.category}/${rp.slug}/`}
              class="group block bg-surface border border-border rounded-2xl p-6 hover:border-brand-200 hover:shadow-lg hover:shadow-brand-500/5 transition-all duration-300"
            >
              <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                <div class="sm:min-w-48">
                  <h3 class="font-bold text-ink group-hover:text-brand-600 transition-colors">{rp.name}</h3>
                  <p class="text-xs text-ink-light/60 uppercase tracking-wider mt-0.5">{rp.category.replace(/-/g, ' ')}</p>
                </div>
                <p class="text-sm text-ink-light flex-1">{rp.reason}</p>
                <svg class="size-5 text-ink-light/40 group-hover:text-brand-600 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <FAQSection items={data.faqs} />

    <CTABanner />
  </main>

  <Footer />
</BaseLayout>
