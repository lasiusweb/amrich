---
import Layout from '../../../layouts/Layout.astro';
import Icon from '../../../components/icons/Icon.astro';
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Monsoon Aquaculture Stress Guide',
  description: 'Step-by-step monsoon pond management for Indian coastal farmers. Prevent ammonia spikes, stabilize pH, and protect shrimp from cyclone stress.',
  author: { '@type': 'Organization', name: 'Amrich Pharma' },
  datePublished: '2026-01-15',
  dateModified: '2026-05-20',
  publisher: { '@type': 'Organization', name: 'Amrich Pharma' },
  image: 'https://imgs.mongabay.com/wp-content/uploads/sites/30/2023/03/30152930/shrimp_farm_NSS04247-1.jpg',
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How soon after rain should I test my water?', acceptedAnswer: { '@type': 'Answer', text: 'Within 2 hours of rainfall onset. Salinity and pH can shift dramatically in the first hour. Early detection gives you more treatment options.' } },
    { '@type': 'Question', name: 'Can I use GASO CLEAN and PRO PLUS together?', acceptedAnswer: { '@type': 'Answer', text: 'Yes — they work synergistically. GASO CLEAN targets ammonia directly, while PRO PLUS rebuilds the broader probiotic community. Apply GASO CLEAN first, wait 12 hours, then apply PRO PLUS for best results.' } },
    { '@type': 'Question', name: 'My pond overflowed — what should I do first?', acceptedAnswer: { '@type': 'Answer', text: 'Check stock survival, restore aeration immediately, test salinity and ammonia, then apply GASO CLEAN if ammonia is elevated. Restocking decisions should wait 72 hours until water stabilizes.' } },
  ],
};
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Monsoon Pond Management for Indian Aquaculture Farmers',
  description: 'Step-by-step guide to protecting shrimp and fish ponds during monsoon season.',
  step: [
    { '@type': 'HowToStep', name: 'Pre-Monsoon Preparation', text: 'Test water parameters, apply probiotics, and reinforce pond bunds before rainfall begins.' },
    { '@type': 'HowToStep', name: 'During Rainfall', text: 'Monitor salinity and pH every 2 hours. Maintain aeration. Reduce feeding by 30-50%.' },
    { '@type': 'HowToStep', name: 'Post-Rain Action', text: 'Test ammonia within 2 hours. Apply GASO CLEAN if elevated. Restore feeding gradually over 48 hours.' },
  ],
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

<style>
  .monsoon-hero {
    position: relative;
    min-height: 40dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .monsoon-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .monsoon-hero-bg .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(10,11,13,0.85) 0%, rgba(10,11,13,0.6) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    padding: var(--space-xxl) 0;
  }
  .hero-content h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    color: var(--on-dark);
    letter-spacing: -1px;
  }
  h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--ink);
  }
  .alert-card {
    border-left: 4px solid var(--accent-yellow);
    padding: var(--space-lg);
  }
  .alert-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  .alert-header h2 {
    font-size: 1.1rem;
    margin: 0;
  }
  .alert-icon {
    color: var(--accent-yellow);
    flex-shrink: 0;
  }

  .step-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-base);
  }
  .step-icon {
    width: 40px;
    height: 40px;
    background: var(--primary);
    color: var(--on-primary);
    border-radius: var(--rounded-full);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .step-item h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: var(--space-xs);
  }
  .step-item p {
    color: var(--body);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .protocol-list {
    margin-top: var(--space-lg);
    display: grid;
    gap: var(--space-base);
  }
  .protocol-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
  }
  .pro-icon {
    color: var(--semantic-up);
    flex-shrink: 0;
    margin-top: 3px;
  }
  .protocol-item span {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--body);
  }

  .faq-item {
    padding: var(--space-base);
    background: var(--canvas);
    border-radius: var(--rounded-sm);
  }
  .faq-q {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }
  .faq-icon {
    color: var(--primary);
    flex-shrink: 0;
  }
  .faq-q h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0;
  }
  .faq-item p {
    color: var(--body);
    line-height: 1.6;
    font-size: 0.95rem;
    margin-left: calc(18px + var(--space-sm));
  }

  .monsoon-cta {
    background: linear-gradient(135deg, rgba(10,11,13,0.95), rgba(20,22,28,0.95));
    text-align: center;
  }

  @media (min-width: 768px) {
    .hero-content h1 { font-size: 2.75rem; }
    h2 { font-size: 1.75rem; }
  }
</style>
<!-- End of Monsoon Guide -->
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Protect Your Aquaculture Pond During Monsoon',
  totalTime: 'P7D',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Strengthen Gut & Immunity', text: 'Apply FARM-C+ in feed at 5 g/kg for 5–7 days before the forecasted rains. Vitamin C and yeast extract boost non-specific immunity, helping shrimp withstand osmotic stress.' },
    { '@type': 'HowToStep', position: 2, name: 'Build Alkalinity Buffer', text: 'Test total alkalinity. If below 100 ppm, apply W-SOFTENER at 2–3 L/acre to stabilize pH and prevent collapse during rain dilution.' },
    { '@type': 'HowToStep', position: 3, name: 'Prepare Aerators & Backup', text: 'Inspect all paddlewheels and diffusers. Clean and test backup generators. Fuel up for 48 hours of continuous operation.' },
    { '@type': 'HowToStep', position: 4, name: 'Restore Pond Probiotics', text: 'Apply PRO PLUS at 500 g/acre to rebuild beneficial bacterial populations washed out by overflow. This suppresses Vibrio and prevents secondary infections.' },
    { '@type': 'HowToStep', position: 5, name: 'Bind Organic Load', text: 'Apply GRO-BIND at 2 kg/acre to bind dead algae, excess feed, and organic sediment. Reduces BOD and prevents post-rain ammonia rebound.' },
    { '@type': 'HowToStep', position: 6, name: 'Gradual Feeding Resume', text: 'Resume feeding at 50% on day 1 post-stabilization. Increase by 10% daily as water parameters normalize. Monitor feed intake closely.' },
    { '@type': 'HowToStep', position: 7, name: 'Final Water Quality Check', text: 'Test ammonia, nitrite, pH, salinity, and alkalinity. Only declare recovery when all parameters are within optimal range for 24 consecutive hours.' },
  ],
};
---

<Layout title="Monsoon Aquaculture Stress Guide | Amrich Pharma" description="Step-by-step monsoon pond management for Indian coastal farmers. Prevent ammonia spikes, stabilize pH, and protect shrimp from cyclone stress.">
  <section class="monsoon-hero">
    <div class="monsoon-hero-bg">
      <img src="https://imgs.mongabay.com/wp-content/uploads/sites/30/2023/03/30152930/shrimp_farm_NSS04247-1.jpg" alt="Monsoon clouds over water" class="hero-bg-img" width="1600" height="900" loading="eager" fetchpriority="high" decoding="async" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <h1>Monsoon Aquaculture Stress Guide</h1>
      <p style="color: var(--on-dark-soft); margin-top: var(--space-sm); max-width: 700px;">
        Protect your crop from salinity crashes, ammonia spikes, and oxygen depletion during heavy rains.
      </p>
    </div>
  </section>

  <section class="section-padding surface-soft">
    <div class="container" style="max-width: 800px;">
      <div class="card alert-card">
        <div class="alert-header"><Icon name="water" size={20} class="alert-icon" /> <h2>Quick Answer — AEO Direct Answer</h2></div>
        <p style="margin-top: var(--space-sm);">
          Heavy rains disrupt salinity, spike ammonia, and crash dissolved oxygen (DO). To protect your crop: reduce feeding by 50–70%, run aerators continuously, stabilize alkalinity with <a href="/products/water-quality-ammonia-control/w-softener">W-SOFTENER</a>, and apply <a href="/products/water-quality-ammonia-control/gaso-clean">GASO CLEAN</a> at 1–2 L/acre (mixed in 30–40L pond water) to biologically eliminate ammonia within 48 hours.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container" style="max-width: 800px;">
      <h2>Why Sudden Rain Destroys Pond Stability</h2>
      <p style="margin-top: var(--space-sm);">
        Monsoon rains cause a cascade of stress factors in aquaculture ponds. Freshwater dilution drops salinity rapidly — sometimes by 10–15 ppt in a single downpour. The sudden osmotic shift shocks shrimp and fish, suppressing their immune systems. pH swings occur as rainwater (pH 5.6) interacts with pond alkalinity. Dead algae from light reduction and temperature drop decompose, releasing toxic ammonia. Dissolved oxygen plunges as bacterial decomposition consumes oxygen faster than aeration can replenish. Without intervention, these compounding stressors trigger disease outbreaks and mass mortality within 72 hours.
      </p>
    </div>
  </section>

  <section class="section-padding surface-soft">
    <div class="container" style="max-width: 800px;">
      <h2>7 Days Before Monsoon: Pre-Stress Preparation</h2>
      <div style="margin-top: var(--space-lg); display: grid; gap: var(--space-xl);">
        <div class="step-item">
          <div class="step-icon"><span>1</span></div>
          <div>
            <h3>Step 1: Strengthen Gut &amp; Immunity</h3>
            <p>Apply <a href="/products/disease-stress-management/farm-c-plus">FARM-C+</a> in feed at 5 g/kg for 5–7 days before the forecasted rains. Vitamin C and yeast extract boost non-specific immunity, helping shrimp withstand osmotic stress.</p>
          </div>
        </div>
        <div class="step-item">
          <div class="step-icon"><span>2</span></div>
          <div>
            <h3>Step 2: Build Alkalinity Buffer</h3>
            <p>Test total alkalinity. If below 100 ppm, apply <a href="/products/water-quality-ammonia-control/w-softener">W-SOFTENER</a> at 2–3 L/acre to stabilize pH and prevent collapse during rain dilution.</p>
          </div>
        </div>
        <div class="step-item">
          <div class="step-icon"><span>3</span></div>
          <div>
            <h3>Step 3: Prepare Aerators &amp; Backup</h3>
            <p>Inspect all paddlewheels and diffusers. Clean and test backup generators. Fuel up for 48 hours of continuous operation. Low DO kills faster than ammonia.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container" style="max-width: 800px;">
      <h2>During Heavy Rainfall: Emergency Protocol</h2>
      <div class="protocol-list">
        <div class="protocol-item"><Icon name="check" size={18} class="pro-icon" /> <span><strong>Reduce Feeding:</strong> Cut feeding by 50–70%. Metabolic rate drops in low salinity — excess feed fouls the pond bottom.</span></div>
        <div class="protocol-item"><Icon name="check" size={18} class="pro-icon" /> <span><strong>Run Aerators Non-Stop:</strong> Maintain DO above 4 ppm. If using <a href="/products/water-quality-ammonia-control/oxy-farm">OXY-FARM</a>, apply at 1 L/acre for immediate oxygen boost.</span></div>
        <div class="protocol-item"><Icon name="check" size={18} class="pro-icon" /> <span><strong>Monitor Salinity:</strong> Check every 6 hours. If salinity drops below 10 ppt, consider controlled freshwater outflow or salt supplementation.</span></div>
        <div class="protocol-item"><Icon name="check" size={18} class="pro-icon" /> <span><strong>Apply GASO CLEAN:</strong> At first sign of ammonia rise (&gt;0.5 ppm), apply <a href="/products/water-quality-ammonia-control/gaso-clean">GASO CLEAN</a> at 1–2 L/acre mixed in 30–40L pond water.</span></div>
        <div class="protocol-item"><Icon name="check" size={18} class="pro-icon" /> <span><strong>Check pH:</strong> If pH drops below 7.0, apply <a href="/products/water-quality-ammonia-control/w-softener">W-SOFTENER</a> at 1 L/acre.</span></div>
      </div>
    </div>
  </section>

  <section class="section-padding surface-soft">
    <div class="container" style="max-width: 800px;">
      <h2>48 Hours Post-Rain: Recovery &amp; Stabilization</h2>
      <div style="margin-top: var(--space-lg); display: grid; gap: var(--space-xl);">
        <div class="step-item">
          <div class="step-icon"><span>1</span></div>
          <div>
            <h3>Restore Pond Probiotics</h3>
            <p>Apply <a href="/products/probiotics-soil-care/pro-plus">PRO PLUS</a> at 500 g/acre to rebuild beneficial bacterial populations washed out by overflow. This suppresses Vibrio and prevents secondary infections.</p>
          </div>
        </div>
        <div class="step-item">
          <div class="step-icon"><span>2</span></div>
          <div>
            <h3>Bind Organic Load</h3>
            <p>Apply <a href="/products/feed-pond-preparers/gro-bind">GRO-BIND</a> at 2 kg/acre to bind dead algae, excess feed, and organic sediment. Reduces BOD and prevents post-rain ammonia rebound.</p>
          </div>
        </div>
        <div class="step-item">
          <div class="step-icon"><span>3</span></div>
          <div>
            <h3>Gradual Feeding Resume</h3>
            <p>Resume feeding at 50% on day 1 post-stabilization. Increase by 10% daily as water parameters normalize. Monitor feed intake closely.</p>
          </div>
        </div>
        <div class="step-item">
          <div class="step-icon"><span>4</span></div>
          <div>
            <h3>Final Water Quality Check</h3>
            <p>Test ammonia, nitrite, pH, salinity, and alkalinity. Only declare recovery when all parameters are within optimal range for 24 consecutive hours.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container" style="max-width: 800px;">
      <h2>Product Pairing Table</h2>
      <div style="overflow-x: auto; margin-top: var(--space-lg);">
        <table style="width: 100%; border-collapse: collapse;">
          <thead>
            <tr style="background: var(--surface-strong);">
              <th style="padding: var(--space-sm); text-align: left; border-bottom: 1px solid var(--hairline);">Product</th>
              <th style="padding: var(--space-sm); text-align: left; border-bottom: 1px solid var(--hairline);">Role in Monsoon</th>
              <th style="padding: var(--space-sm); text-align: left; border-bottom: 1px solid var(--hairline);">Dosage</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td style="padding: var(--space-sm); border-bottom: 1px solid var(--hairline-soft);"><a href="/products/water-quality-ammonia-control/w-softener">W-SOFTENER</a></td>
              <td style="padding: var(--space-sm); border-bottom: 1px solid var(--hairline-soft);">Alkalinity buffer, pH stabilizer</td>
              <td style="padding: var(--space-sm); border-bottom: 1px solid var(--hairline-soft);">2–3 L/acre pre-rain; 1 L/acre during pH drop</td>
            </tr>
            <tr>
              <td style="padding: var(--space-sm); border-bottom: 1px solid var(--hairline-soft);"><a href="/products/disease-stress-management/farm-c-plus">FARM-C+</a></td>
              <td style="padding: var(--space-sm); border-bottom: 1px solid var(--hairline-soft);">Immune booster, stress resistance</td>
              <td style="padding: var(--space-sm); border-bottom: 1px solid var(--hairline-soft);">5 g/kg feed for 5–7 days pre-rain</td>
            </tr>
            <tr>
              <td style="padding: var(--space-sm); border-bottom: 1px solid var(--hairline-soft);"><a href="/products/water-quality-ammonia-control/gaso-clean">GASO CLEAN</a></td>
              <td style="padding: var(--space-sm); border-bottom: 1px solid var(--hairline-soft);">Biological ammonia removal</td>
              <td style="padding: var(--space-sm); border-bottom: 1px solid var(--hairline-soft);">1–2 L/acre in 30–40L water</td>
            </tr>
            <tr>
              <td style="padding: var(--space-sm); border-bottom: 1px solid var(--hairline-soft);"><a href="/products/probiotics-soil-care/pro-plus">PRO PLUS</a></td>
              <td style="padding: var(--space-sm); border-bottom: 1px solid var(--hairline-soft);">Probiotic restoration, Vibrio suppression</td>
              <td style="padding: var(--space-sm); border-bottom: 1px solid var(--hairline-soft);">500 g/acre post-rain</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section-padding surface-soft">
    <div class="container" style="max-width: 800px;">
      <h2>Frequently Asked Questions</h2>
      <div style="margin-top: var(--space-lg); display: grid; gap: var(--space-lg);">
        <div class="faq-item">
          <div class="faq-q"><Icon name="farmer" size={18} class="faq-icon" /> <h3>How soon after rain should I test my water?</h3></div>
          <p>Within 2 hours of rainfall onset. Salinity and pH can shift dramatically in the first hour. Early detection gives you more treatment options.</p>
        </div>
        <div class="faq-item">
          <div class="faq-q"><Icon name="farmer" size={18} class="faq-icon" /> <h3>Can I use GASO CLEAN and PRO PLUS together?</h3></div>
          <p>Yes — they work synergistically. GASO CLEAN targets ammonia directly, while PRO PLUS rebuilds the broader probiotic community. Apply GASO CLEAN first, wait 12 hours, then apply PRO PLUS for best results.</p>
        </div>
        <div class="faq-item">
          <div class="faq-q"><Icon name="farmer" size={18} class="faq-icon" /> <h3>My pond overflowed — what should I do first?</h3></div>
          <p>Check stock survival, restore aeration immediately, test salinity and ammonia, then apply GASO CLEAN if ammonia is elevated. Restocking decisions should wait 72 hours until water stabilizes.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding monsoon-cta">
    <div class="container" style="text-align: center;">
      <h2 style="color: var(--on-dark);">Need a Custom Plan for Your Pond?</h2>
      <p style="color: var(--on-dark-soft); margin-top: var(--space-sm); max-width: 500px; margin-left: auto; margin-right: auto;">
        Tell us your pond size, species, and location — we'll send a personalized monsoon protocol.
      </p>
      <button data-modal="quote-form" class="btn-primary" style="margin-top: var(--space-lg);">
        Get My Custom Monsoon Plan
      </button>
    </div>
  </section>
</Layout>

