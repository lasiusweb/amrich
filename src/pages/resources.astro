---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.ts';

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Resources & Guides | Amrich Pharma",
  "description": "Free aquaculture resources, farming guides, and technical documentation from Amrich Pharma.",
  "url": `${site.url}/resources`,
};

const resources = [
  {
    category: 'Farming Guides',
    icon: '📘',
    items: [
      { title: 'Shrimp Disease Prevention Guide', href: '/blog/shrimp-disease-prevention-guide/', description: 'Complete strategies for preventing WSSV, EMS, and Vibrio infections.' },
      { title: 'Ammonia Control Manual', href: '/blog/control-ammonia-shrimp-ponds/', description: 'Understanding and managing ammonia levels in aquaculture ponds.' },
      { title: 'Biofloc Technology Handbook', href: '/blog/biofloc-technology-beginners-guide/', description: 'Getting started with biofloc systems for higher productivity.' },
    ],
  },
  {
    category: 'Product Information',
    icon: '🧪',
    items: [
      { title: 'Disease & Stress Management', href: '/products/disease-stress-management/', description: 'Immune boosters, antimicrobials, and stress reducers.' },
      { title: 'Feed & Pond Preparers', href: '/products/feed-pond-preparers/', description: 'Growth supplements, pond prep, and larval nutrition.' },
      { title: 'Probiotics & Soil Care', href: '/products/probiotics-soil-care/', description: 'Beneficial bacteria, soil treatment, and biofloc starters.' },
      { title: 'Water Quality & Ammonia Control', href: '/products/water-quality-ammonia-control/', description: 'Ammonia neutralizers, oxygen enhancers, and pH buffers.' },
    ],
  },
  {
    category: 'Quick Reference',
    icon: '📋',
    items: [
      { title: 'Water Quality Parameters', href: '#', description: 'Optimal ranges for temperature, pH, DO, ammonia, and alkalinity.' },
      { title: 'Feed Conversion Ratios', href: '#', description: 'Expected FCR benchmarks by species and grow-out stage.' },
      { title: 'Disease Identification Chart', href: '#', description: 'Visual guide to common shrimp and fish diseases.' },
    ],
  },
];
---

<BaseLayout
  title="Resources & Guides | Amrich Pharma"
  description="Free aquaculture resources, farming guides, and technical documentation from Amrich Pharma."
  schema={schema}
>
  <Header />

  <main id="main-content" class="flex-1">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Resources' },
    ]} />

    <section class="bg-gradient-to-br from-brand-900 via-brand-800 to-ocean-900 text-white py-20">
      <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">
            Resources & Guides
          </h1>
          <p class="text-lg text-white/70 leading-relaxed">
            Free knowledge to help you succeed in aquaculture. From beginner guides to advanced management techniques.
          </p>
        </div>
      </div>
    </section>

    <section class="section-padding">
      <div class="container-wide max-w-5xl">
        <div class="space-y-12">
          {resources.map((section) => (
            <div>
              <div class="flex items-center gap-3 mb-6">
                <span class="text-2xl">{section.icon}</span>
                <h2 class="font-display text-2xl font-bold text-ink">{section.category}</h2>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {section.items.map((item) => (
                  <a
                    href={item.href}
                    class="group block bg-surface border border-border rounded-2xl p-6 hover:border-brand-200 hover:shadow-lg hover:shadow-brand-500/5 transition-all duration-300"
                  >
                    <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-brand-600 transition-colors">
                      {item.title}
                    </h3>
                    <p class="text-sm text-ink-light leading-relaxed mb-3">
                      {item.description}
                    </p>
                    <div class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 group-hover:text-brand-700 transition-colors">
                      {item.href === '#' ? 'Coming Soon' : 'View Resource'}
                      <svg class="size-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-padding border-t border-border bg-surface-muted">
      <div class="container-wide max-w-3xl text-center">
        <h2 class="font-display text-2xl font-bold text-ink mb-4">
          Need Technical Support?
        </h2>
        <p class="text-ink-light mb-6">
          Our team of aquaculture scientists is ready to help with any questions about product application, disease management, or water quality.
        </p>
        <a
          href="/contact/"
          class="inline-flex items-center justify-center gap-2 px-8 py-3 text-base font-semibold text-white bg-brand-600 rounded-xl hover:bg-brand-700 transition-colors focus-ring"
        >
          Contact Our Team
          <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
