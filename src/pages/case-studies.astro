---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.ts';
import { getIcon } from '../data/icons.ts';

const caseStudies = [
  {
    title: 'Kakinada Shrimp Farm — Ammonia Recovery & Survival Boost',
    location: 'Kakinada, Andhra Pradesh',
    date: 'March 2025',
    challenge: 'Ammonia spike reaching 2.1 ppm across 12 acres of shrimp ponds. Survival rate dropping rapidly with visible stock stress and erratic feeding behavior.',
    solution: 'Applied PRO PLUS + GASO CLEAN protocol. PRO PLUS for organic load reduction and soil health, GASO CLEAN for biological ammonia and nitrite elimination.',
    results: ['Ammonia dropped from 2.1 to 0.4 ppm in 5 days', 'DO levels recovered from 3.2 to 5.8 mg/L', 'Survival rate improved by 18% this cycle', 'Feed intake normalized within 72 hours'],
    products: ['PRO PLUS', 'GASO CLEAN'],
    quote: 'After using PRO PLUS + GASO CLEAN, ammonia dropped from 2.1 to 0.4 ppm in 5 days. Survival rate improved by 18% this cycle.',
    quoteAuthor: 'Ramesh K., Commercial Grower',
  },
  {
    title: 'Nellore Tiger Prawn Farm — Gill Rot Elimination',
    location: 'Nellore, Tamil Nadu',
    date: 'January 2025',
    challenge: 'Blackgill and Browngill infections across 8 ponds of tiger prawns. Previous iodine treatments caused pond shock and inconsistent molting.',
    solution: 'Applied FARM 80% at recommended dosage with clean sand broadcasting during calm weather, followed by FARM-C+ for stress recovery.',
    results: ['Gill rot cleared within 5 days without pond shock', 'Molting became uniform across all ponds', 'Yield per acre increased by 120 kg', 'No recurrence in subsequent 60 days'],
    products: ['FARM 80%', 'FARM-C+'],
    quote: 'FARM 80% cleared gill rot without shocking the pond. Moulting became uniform. Yield per acre went up by 120 kg.',
    quoteAuthor: 'S. Venkat, Mid-Scale Farmer',
  },
  {
    title: 'Odisha White Shrimp Farm — Biofloc Stabilization',
    location: 'Jagatsinghpur, Odisha',
    date: 'November 2024',
    challenge: 'New 5-hectare biofloc system experiencing unstable floc development, high TAN levels, and poor shrimp survival in early nursery phase.',
    solution: 'Established with FARM PRO for water column probiotics, BLOOMER for stable phytoplankton, and OXY-FARM for nitrification and DO support.',
    results: ['Floc system stabilized within 10 days', 'TAN levels dropped from 2.5 to 0.3 ppm', 'Nursery survival reached 92%', 'Zero water exchange from Week 4 onward'],
    products: ['FARM PRO', 'BLOOMER', 'OXY-FARM'],
    quote: 'Getting the biofloc right from day one was critical. FARM PRO and OXY-FARM gave us the stability we needed.',
    quoteAuthor: 'Pradeep S., Farm Owner',
  },
  {
    title: 'Nagapattinam Vannamei Farm — Monsoon Stability & Record Survival',
    location: 'Nagapattinam, Tamil Nadu',
    date: 'June 2025',
    challenge: 'Maintaining pond stability during monsoon season with unpredictable weather patterns, risk of water quality crashes, and high mortality rates.',
    solution: 'Applied PRO PLUS for organic load reduction and soil health, FARM PRO for water column probiotics, and GASO CLEAN for biological ammonia and nitrite elimination. Amrich technical team conducted two on-site visits to set up a monitoring schedule.',
    results: ['Achieved highest-ever survival rate of 91%', 'FCR of 1.28 using PRO PLUS + FARM PRO + GASO CLEAN protocol', 'Cleanest pond bottoms ever observed', 'Water colour stayed stable throughout monsoon with zero crashes'],
    products: ['PRO PLUS', 'FARM PRO', 'GASO CLEAN'],
    quote: 'Using PRO PLUS and FARM PRO together gave me the cleanest pond bottoms I have ever seen. My water colour stayed stable throughout the monsoon — no crashes, no panic. The technical team from Amrich visited my farm twice and helped me set up a monitoring schedule that caught problems before they became disasters.',
    quoteAuthor: 'Murugan S., Vannamei Farmer',
  },
  {
    title: 'Gujarat Fish Farm — Antibiotic-Free Disease Control',
    location: 'Surat, Gujarat',
    date: 'August 2024',
    challenge: 'Recurring Aeromonas infections in freshwater fish ponds with increasing antibiotic resistance. Mortality rates averaging 25% per cycle.',
    solution: 'Replaced antibiotics with GUT-X for gut health, FARMADINE for disease control, and FARM-C+ for immune support during recovery.',
    results: ['Disease incidence reduced by 90%', 'Complete elimination of antibiotic use', 'Mortality dropped from 25% to 3%', 'Products passed organic compliance review'],
    products: ['GUT-X', 'FARMADINE', 'FARM-C+'],
    quote: 'We were trapped in an antibiotic cycle. Amrich Pharma helped us break free, and our fish are healthier than ever.',
    quoteAuthor: 'Bharat P., Farm Manager',
  },
];

const stats = {
  totalFarmers: 6000,
  totalStories: 5,
  beforeAfter: {
    ammonia: { before: '1.8 ppm', after: '0.3 ppm' },
    do: { before: '3.2 mg/L', after: '5.8 mg/L' },
    fcr: { before: '1.9', after: '1.3' },
    mortality: { before: '22%', after: '8%' },
  },
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "name": "Case Studies | Amrich Pharma",
      "description": "Real-world success stories from Indian coastal farms using Amrich Pharma aquaculture products.",
      "url": `${site.url}/case-studies/`,
      "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": 5,
      },
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": "Case Studies" },
      ],
    },
  ],
};
---

<BaseLayout
  title="Case Studies | Amrich Pharma"
  description="Real results from Indian coastal farms. See how Amrich Pharma products have transformed aquaculture operations in AP, TN, Odisha, and Gujarat."
  schema={schema}
>
  <Header />

  <main id="main-content" class="flex-1">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Case Studies' },
    ]} />

    <section class="bg-gradient-to-br from-brand-900 via-brand-800 to-ocean-900 text-white py-20">
      <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">
            Real Ponds. Real Results.
          </h1>
          <p class="text-lg text-white/70 leading-relaxed mb-8">
            Do not just take our word for it. Here is what coastal farmers report after switching to Amrich Pharma solutions.
          </p>
        </div>
      </div>
    </section>

    <section class="section-padding bg-surface-muted border-b border-border">
      <div class="container-wide max-w-4xl">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          {[
            { label: 'Farmer Stories', value: `${stats.totalStories}`, subtitle: 'documented case studies' },
            { label: 'Farmers Reached', value: `${stats.totalFarmers}+`, subtitle: 'across India' },
            { label: 'Avg FCR', value: stats.beforeAfter.fcr.after, subtitle: 'feed conversion ratio' },
            { label: 'Avg Survival', value: '91%', subtitle: 'reported survival rate' },
          ].map((stat) => (
            <div class="bg-brand-900 text-white rounded-2xl p-5 text-center">
              <div class="font-display text-3xl font-bold mb-1">{stat.value}</div>
              <div class="text-sm text-white/70">{stat.label}</div>
              <div class="text-xs text-white/40 mt-1">{stat.subtitle}</div>
            </div>
          ))}
        </div>

        <h2 class="font-display text-2xl font-bold text-ink text-center mb-8">Before / After Dashboard</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { label: 'Ammonia', before: stats.beforeAfter.ammonia.before, after: stats.beforeAfter.ammonia.after, color: 'text-red-500' },
            { label: 'DO Levels', before: stats.beforeAfter.do.before, after: stats.beforeAfter.do.after, color: 'text-brand-500' },
            { label: 'Feed Conversion', before: stats.beforeAfter.fcr.before, after: stats.beforeAfter.fcr.after, color: 'text-ocean-500' },
            { label: 'Mortality', before: stats.beforeAfter.mortality.before, after: stats.beforeAfter.mortality.after, color: 'text-brand-500' },
          ].map((metric) => (
            <div class="bg-surface border border-border rounded-2xl p-5 text-center">
              <div class="text-xs font-semibold text-ink-light/60 uppercase tracking-wider mb-3">{metric.label}</div>
              <div class="flex items-center justify-center gap-3 mb-2">
                <div>
                  <div class="text-xs text-ink-light/50 mb-0.5">Before</div>
                  <div class="text-lg font-bold text-red-400">{metric.before}</div>
                </div>
                <span class="text-brand-500 text-lg" set:html={getIcon('arrow')} />
                <div>
                  <div class="text-xs text-ink-light/50 mb-0.5">After</div>
                  <div class="text-lg font-bold" class:list={[metric.color]}>{metric.after}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-padding">
      <div class="container-wide max-w-4xl space-y-10">
        {caseStudies.map((study, index) => (
          <article class="bg-surface border border-border rounded-2xl overflow-hidden">
            <div class="bg-gradient-to-r from-brand-900 via-brand-800 to-ocean-900 px-8 py-6 text-white">
              <div class="flex items-center gap-3 mb-1">
                <span class="text-sm text-white/70">{study.location} &middot; {study.date}</span>
              </div>
              <h2 class="font-display text-xl font-bold">{study.title}</h2>
            </div>

            <div class="p-8 space-y-6">
              <div>
                <h3 class="text-xs font-bold text-red-500 uppercase tracking-wider mb-2">Challenge</h3>
                <p class="text-sm text-ink-light leading-relaxed">{study.challenge}</p>
              </div>

              <div>
                <h3 class="text-xs font-bold text-brand-600 uppercase tracking-wider mb-2">Solution</h3>
                <p class="text-sm text-ink-light leading-relaxed">{study.solution}</p>
              </div>

              <div>
                <h3 class="text-xs font-bold text-ocean-600 uppercase tracking-wider mb-2">Results</h3>
                <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                  {study.results.map((result) => (
                    <li class="flex items-start gap-2">
                      <span class="size-4 text-brand-500 mt-0.5 shrink-0" set:html={getIcon('check')} />
                      <span class="text-sm text-ink-light">{result}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div>
                <h3 class="text-xs font-bold text-ink-light/60 uppercase tracking-wider mb-2">Products Used</h3>
                <div class="flex flex-wrap gap-2">
                  {study.products.map((product) => (
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-brand-50 dark:bg-brand-900/20 text-brand-700 dark:text-brand-300">
                      {product}
                    </span>
                  ))}
                </div>
              </div>

              <div class="bg-surface-muted rounded-xl p-6 border-l-4 border-brand-500">
                <p class="text-sm text-ink italic leading-relaxed mb-2">&ldquo;{study.quote}&rdquo;</p>
                <p class="text-xs text-ink-light/70 font-medium">&mdash; {study.quoteAuthor}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <CTABanner
      heading="Submit Your Pond Results"
      description="Share your success story with us and help other farmers grow better."
      ctaLabel="Book a Free Pond Audit"
      ctaHref="/contact"
    />
  </main>

  <Footer />
</BaseLayout>
