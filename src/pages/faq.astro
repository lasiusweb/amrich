---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQSection from '../components/FAQSection.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.ts';

const faqItems = [
  {
    question: 'What is Amrich Pharma?',
    answer: 'Amrich Pharma is an ISO 9001:2015 certified aquaculture health company based in Mumbai, India. We formulate eco-safe probiotics, water quality solutions, and disease management products for shrimp and fish farmers across coastal India.',
  },
  {
    question: 'What products does Amrich Pharma offer?',
    answer: 'We offer 16 specialized products across four categories: Probiotics & Soil Care, Disease & Stress Management, Feed & Pond Preparers, and Water Quality & Ammonia Control. Our range includes FARM PRO, PRO PLUS, GASO CLEAN, OXY-FARM, FARMADINE, and more.',
  },
  {
    question: 'How do I choose the right products for my farm?',
    answer: 'Identify your primary challenge — poor water quality, disease, slow growth, or pond bottom issues. Each product page on our site includes detailed descriptions, application steps, and dosage guides. Contact our technical team for personalized recommendations.',
  },
  {
    question: 'Are Amrich Pharma products safe for all species?',
    answer: 'Yes, our products are formulated for shrimp, prawns, fish, and other aquaculture species. Each product page lists specific target species and water parameter ranges.',
  },
  {
    question: 'How do I place an order?',
    answer: 'Contact us via email at amrichpharma@gmail.com or phone. Our team will assist with product selection, pricing, and delivery arrangements across Indian coastal regions.',
  },
  {
    question: 'Do you offer technical support?',
    answer: 'Yes, we provide free technical consultation to all customers. Our team can help with product application, disease identification, water quality management, and pond-specific dosing plans.',
  },
  {
    question: 'What is your delivery area?',
    answer: 'We currently serve farms across Andhra Pradesh, Tamil Nadu, Odisha, Gujarat, and Kerala. Contact us for delivery availability to your specific location.',
  },
  {
    question: 'Can I get product samples before ordering?',
    answer: 'Yes, we offer sample packs for most products. Contact our team to request samples for evaluation on your farm.',
  },
  {
    question: 'How should I store Amrich Pharma products?',
    answer: 'Most products should be stored in a cool, dry place away from direct sunlight. Probiotics are heat stable and do not require refrigeration. Always check the product label for specific storage instructions.',
  },
  {
    question: 'Do you offer bulk pricing for large farms?',
    answer: 'Yes, we offer competitive bulk pricing for large-scale operations. Contact our sales team with your requirements for a custom quote.',
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "name": "Frequently Asked Questions | Amrich Pharma",
      "description": "Common questions about Amrich Pharma aquaculture products, ordering, technical support, and delivery.",
      "url": `${site.url}/faq`,
      "mainEntity": faqItems.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer,
        },
      })),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": "FAQ" },
      ],
    },
  ],
};
---

<BaseLayout
  title="Frequently Asked Questions | Amrich Pharma"
  description="Common questions about Amrich Pharma aquaculture products, ordering, technical support, delivery, and farm optimization."
  schema={schema}
>
  <Header />

  <main id="main-content" class="flex-1">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'FAQ' },
    ]} />

    <section class="bg-gradient-to-br from-brand-900 via-brand-800 to-ocean-900 text-white py-20">
      <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">
            Frequently Asked Questions
          </h1>
          <p class="text-lg text-white/70 leading-relaxed">
            Find answers to common questions about our products, ordering process, and technical support.
          </p>
        </div>
      </div>
    </section>

    <FAQSection items={faqItems} />

    <section class="section-padding border-t border-border">
      <div class="container-wide max-w-3xl text-center">
        <h2 class="font-display text-2xl font-bold text-ink mb-4">
          Still Have Questions?
        </h2>
        <p class="text-ink-light mb-6">
          Our team is ready to help with any questions about product selection, application, or farm optimization.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact/"
            class="inline-flex items-center justify-center gap-2 px-8 py-3 text-base font-semibold text-white bg-brand-600 rounded-xl hover:bg-brand-700 transition-colors focus-ring"
          >
            Contact Us
          </a>
          <a
            href="/resources/"
            class="inline-flex items-center justify-center gap-2 px-8 py-3 text-base font-semibold text-brand-600 bg-surface border-2 border-brand-600 rounded-xl hover:bg-brand-50 dark:hover:bg-brand-900/20 transition-colors focus-ring"
          >
            Browse Resources
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
