---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.ts';

const steps = [
  {
    number: '01',
    title: 'Identify Your Needs',
    description: 'Browse our product categories or take our quick assessment to find the right solutions for your farm.',
    link: '/products/',
    linkText: 'View Products',
  },
  {
    number: '02',
    title: 'Request a Quote',
    description: 'Contact our sales team with your product selection, farm size, and delivery location for a personalized quote.',
    link: '/contact/',
    linkText: 'Contact Sales',
  },
  {
    number: '03',
    title: 'Confirm & Pay',
    description: 'Review your quote, confirm your order, and choose from our flexible payment options.',
    link: null,
    linkText: null,
  },
  {
    number: '04',
    title: 'Delivery & Support',
    description: 'Receive your products with full technical documentation. Our team provides ongoing support for product application.',
    link: '/resources/',
    linkText: 'View Resources',
  },
];

const benefits = [
  { title: 'Farm-Tested Products', description: 'Every product is field-tested across hundreds of farms in coastal India.' },
  { title: 'Scientific Formulation', description: 'Developed by aquaculture scientists with decades of combined experience.' },
  { title: 'Technical Support', description: 'Free consultation on product application, disease management, and water quality.' },
  { title: 'Regional Delivery', description: 'Fast delivery across Vietnam, Malaysia, Thailand, Indonesia, and the Philippines.' },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "How to Order | Amrich Pharma",
  "description": "Step-by-step guide to ordering Amrich Pharma aquaculture products for your farm.",
  "url": `${site.url}/how-to-order`,
};
---

<BaseLayout
  title="How to Order | Amrich Pharma"
  description="Step-by-step guide to ordering Amrich Pharma aquaculture products for your farm."
  schema={schema}
>
  <Header />

  <main id="main-content" class="flex-1">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'How to Order' },
    ]} />

    <section class="bg-gradient-to-br from-brand-900 via-brand-800 to-ocean-900 text-white py-20">
      <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">
            How to Order
          </h1>
          <p class="text-lg text-white/70 leading-relaxed">
            Getting started with Amrich Pharma products is simple. Follow these four steps to improve your farm.
          </p>
        </div>
      </div>
    </section>

    <section class="section-padding">
      <div class="container-wide max-w-4xl">
        <div class="grid gap-8">
          {steps.map((step, index) => (
            <div class="flex gap-6 items-start relative">
              <div class="shrink-0 size-14 rounded-full bg-brand-50 dark:bg-brand-900/20 border border-brand-200 dark:border-brand-800 flex items-center justify-center">
                <span class="font-display text-lg font-bold text-brand-600">{step.number}</span>
              </div>
              {index < steps.length - 1 && (
                <div class="hidden md:block absolute top-14 left-7 w-0.5 h-8 bg-border" />
              )}
              <div class="flex-1 pt-2">
                <h2 class="font-display text-xl font-bold text-ink mb-2">{step.title}</h2>
                <p class="text-sm text-ink-light leading-relaxed mb-3">{step.description}</p>
                {step.link && (
                  <a
                    href={step.link}
                    class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:text-brand-700 transition-colors"
                  >
                    {step.linkText}
                    <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-padding bg-surface-muted border-t border-border">
      <div class="container-wide">
        <div class="text-center mb-12">
          <h2 class="font-display text-3xl font-bold text-ink mb-4">
            Why Order from Amrich Pharma?
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {benefits.map((benefit, i) => (
            <div class="bg-surface border border-border rounded-2xl p-6 text-center">
              <div class="size-12 rounded-xl bg-brand-50 dark:bg-brand-900/20 flex items-center justify-center mx-auto mb-4">
                <svg class="size-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  {i === 0 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />}
                  {i === 1 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />}
                  {i === 2 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />}
                  {i === 3 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />}
                </svg>
              </div>
              <h3 class="text-lg font-bold text-ink mb-2">{benefit.title}</h3>
              <p class="text-sm text-ink-light leading-relaxed">{benefit.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTABanner />
  </main>

  <Footer />
</BaseLayout>
