---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.ts';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Terms of Service | Amrich Pharma",
  "description": "Terms and conditions governing the use of Amrich Pharma website and services.",
  "url": `${site.url}/terms`,
};
---

<BaseLayout
  title="Terms of Service | Amrich Pharma"
  description="Terms and conditions governing the use of Amrich Pharma website and services."
  schema={schema}
>
  <Header />

  <main id="main-content" class="flex-1">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Terms of Service' },
    ]} />

    <section class="section-padding">
      <div class="container-wide max-w-4xl">
        <h1 class="font-display text-4xl font-bold text-ink mb-8">Terms of Service</h1>

        <div class="space-y-8">
          <div>
            <p class="text-sm text-ink-light leading-relaxed">
              Welcome to Amrich Pharma. By accessing or using our website and services, you agree to be bound by the following terms and conditions.
            </p>
          </div>

          <div>
            <h2 class="font-display text-xl font-bold text-ink mb-3">1. Use of Website</h2>
            <p class="text-sm text-ink-light leading-relaxed">
              This website is provided for informational purposes about our aquaculture products and services. You may browse the site and download information for personal, non-commercial use. You may not modify, distribute, or republish any content from this site without our written permission.
            </p>
          </div>

          <div>
            <h2 class="font-display text-xl font-bold text-ink mb-3">2. Product Information</h2>
            <p class="text-sm text-ink-light leading-relaxed">
              While we strive to provide accurate product information, descriptions, and specifications, we do not warrant that the information on this site is complete, reliable, or current. Product details are subject to change without notice.
            </p>
          </div>

          <div>
            <h2 class="font-display text-xl font-bold text-ink mb-3">3. Orders and Pricing</h2>
            <p class="text-sm text-ink-light leading-relaxed">
              Product availability and pricing are subject to change without notice. All orders are subject to acceptance and availability. We reserve the right to refuse or cancel any order for any reason.
            </p>
          </div>

          <div>
            <h2 class="font-display text-xl font-bold text-ink mb-3">4. Limitation of Liability</h2>
            <p class="text-sm text-ink-light leading-relaxed">
              Amrich Pharma shall not be liable for any indirect, incidental, special, or consequential damages arising from the use of this website or our products.
            </p>
          </div>

          <div>
            <h2 class="font-display text-xl font-bold text-ink mb-3">5. Intellectual Property</h2>
            <p class="text-sm text-ink-light leading-relaxed">
              All content on this website, including text, graphics, logos, and trademarks, is the property of Amrich Pharma and is protected by applicable intellectual property laws.
            </p>
          </div>

          <div>
            <h2 class="font-display text-xl font-bold text-ink mb-3">6. Privacy</h2>
            <p class="text-sm text-ink-light leading-relaxed">
              Your use of this website is also governed by our <a href="/privacy" class="text-brand-600 hover:text-brand-700">Privacy Policy</a>.
            </p>
          </div>

          <div>
            <h2 class="font-display text-xl font-bold text-ink mb-3">7. Contact</h2>
            <p class="text-sm text-ink-light leading-relaxed">
              For questions about these terms, please contact us at:<br />
              <strong class="text-ink">Amrich Pharma</strong><br />
              Email: <a href={`mailto:${site.email}`} class="text-brand-600 hover:text-brand-700">{site.email}</a><br />
              Location: {site.location}
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
