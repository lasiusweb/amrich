---
export interface Props {
  slug: string;
  name: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
}
const { slug, name, width = 400, height = 300, class: className = '', loading = 'lazy' } = Astro.props;
// Unsplash aquaculture-themed fallback images mapped by product
const imageMap: Record<string, string> = {
  'pro-plus': 'https://imgs.mongabay.com/wp-content/uploads/sites/30/2023/03/30152930/shrimp_farm_NSS04247-1.jpg',
  'farm-pro': 'https://www.globalseafood.org/wp-content/uploads/2019/10/India-shrimp-ponds_1500.jpg',
  'farm-ps': 'https://sharangaaqua.com/images/operation4.jpg',
  'bloomer': 'https://www.aquaculturealliance.org/wp-content/uploads/2019/03/Shrimp-Forum-2019_Pic-1-960x720.jpg',
  'gut-x': 'https://imgs.mongabay.com/wp-content/uploads/sites/30/2023/03/30152930/shrimp_farm_NSS04247-1.jpg',
  'gaso-clean': 'https://www.globalseafood.org/wp-content/uploads/2019/10/India-shrimp-ponds_1500.jpg',
  'w-softener': 'https://sharangaaqua.com/images/operation4.jpg',
  'oxy-farm': 'https://www.aquaculturealliance.org/wp-content/uploads/2019/03/Shrimp-Forum-2019_Pic-1-960x720.jpg',
  'farmamin': 'https://imgs.mongabay.com/wp-content/uploads/sites/30/2023/03/30152930/shrimp_farm_NSS04247-1.jpg',
  'farmadine': 'https://www.globalseafood.org/wp-content/uploads/2019/10/India-shrimp-ponds_1500.jpg',
  'farm-80': 'https://sharangaaqua.com/images/operation4.jpg',
  'farm-c-plus': 'https://www.aquaculturealliance.org/wp-content/uploads/2019/03/Shrimp-Forum-2019_Pic-1-960x720.jpg',
  'shrimp-care': 'https://imgs.mongabay.com/wp-content/uploads/sites/30/2023/03/30152930/shrimp_farm_NSS04247-1.jpg',
  'omega-booster': 'https://www.globalseafood.org/wp-content/uploads/2019/10/India-shrimp-ponds_1500.jpg',
  'gro-bind': 'https://sharangaaqua.com/images/operation4.jpg',
  'easy-lite': 'https://www.aquaculturealliance.org/wp-content/uploads/2019/03/Shrimp-Forum-2019_Pic-1-960x720.jpg',
};
const fallback = 'https://imgs.mongabay.com/wp-content/uploads/sites/30/2023/03/30152930/shrimp_farm_NSS04247-1.jpg';
const src = imageMap[slug] || fallback;
---

<img src={src} alt={name} width={width} height={height} loading={loading} class={className} decoding="async" />
