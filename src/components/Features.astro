---
const features = [
  {
    title: 'Science-Backed',
    description: 'Every product is formulated by aquaculture scientists and rigorously tested for efficacy and safety in Indian coastal conditions.',
  },
  {
    title: 'Proven Results',
    description: 'Trusted by over 3,000 farmers across coastal India with documented improvements in yield and survival rates.',
  },
  {
    title: 'Eco-Friendly',
    description: 'Microbial and herbal formulations that protect aquatic ecosystems while maximizing farm productivity.',
  },
  {
    title: 'Farmer-First Support',
    description: 'Technical consultation and pond-specific dosing plans from aquaculture experts who understand Indian farming conditions.',
  },
];
---

<section class="section-padding">
  <div class="container-wide">
    <div class="text-center mb-14">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-ink mb-4 text-balance">
        Why Choose Amrich Pharma?
      </h2>
      <p class="text-lg text-ink-light max-w-2xl mx-auto">
        We combine scientific expertise with practical experience to deliver aquaculture solutions that work for Indian farmers.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature, i) => (
        <div class="group relative bg-surface border border-border rounded-2xl p-8 hover:border-brand-200 hover:shadow-lg hover:shadow-brand-500/5 transition-all duration-300">
          <div class="size-12 rounded-xl bg-brand-50 dark:bg-brand-900/20 flex items-center justify-center p-2.5 mb-5 group-hover:scale-110 transition-transform duration-300">
            <svg class="size-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              {i === 0 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />}
              {i === 1 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />}
              {i === 2 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />}
              {i === 3 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />}
            </svg>
          </div>
          <h3 class="text-lg font-bold text-ink mb-2">{feature.title}</h3>
          <p class="text-sm text-ink-light leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
