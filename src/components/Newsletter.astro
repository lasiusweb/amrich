---

---

<section class="section-padding bg-surface-muted border-t border-border">
  <div class="container-wide">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-ink mb-4">
        Stay Updated
      </h2>
      <p class="text-lg text-ink-light mb-8">
        Get the latest aquaculture insights, product updates, and farming tips delivered to your inbox.
      </p>
      <form
        class="flex flex-col sm:flex-row gap-3"
        action="https://amrich.us21.list-manage.com/subscribe/post"
        method="POST"
        target="_blank"
      >
        <input
          type="email"
          name="EMAIL"
          placeholder="Enter your email"
          required
          class="flex-1 px-4 py-3 rounded-xl border border-border bg-surface text-ink placeholder:text-ink-light/50 focus:outline-none focus:ring-2 focus:ring-brand-500 transition-shadow"
        />
        <button
          type="submit"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-semibold text-white bg-brand-600 rounded-xl hover:bg-brand-700 transition-colors focus-ring"
        >
          Subscribe
          <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </button>
      </form>
      <p class="text-xs text-ink-light/50 mt-4">
        No spam. Unsubscribe anytime. We respect your privacy.
      </p>
    </div>
  </div>
</section>
