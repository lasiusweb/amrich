---
interface Props {
  productName: string;
  categoryName: string;
}

const { productName, categoryName } = Astro.props;
const productParam = encodeURIComponent(productName);
---

<div id="sticky-cta" class="fixed bottom-0 left-0 right-0 z-40 bg-surface/95 backdrop-blur-md border-t border-border shadow-lg translate-y-full transition-transform duration-300">
  <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8 py-3">
    <div class="flex items-center justify-between gap-4">
      <div class="hidden sm:block">
        <p class="text-sm font-semibold text-ink">{productName}</p>
        <p class="text-xs text-ink-light/60">{categoryName}</p>
      </div>
      <div class="flex items-center gap-3 w-full sm:w-auto">
        <a
          href={`/contact?product=${productParam}`}
          class="flex-1 sm:flex-none inline-flex items-center justify-center gap-2 px-6 py-2.5 text-sm font-semibold text-white bg-brand-600 rounded-xl hover:bg-brand-700 transition-colors focus-ring"
        >
          Get a Quote
          <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="tel:+91222893XXXX"
          class="hidden sm:inline-flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-ink border border-border rounded-xl hover:border-brand-200 hover:text-brand-600 transition-all focus-ring"
        >
          <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call Us
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  const cta = document.getElementById('sticky-cta');
  if (cta) {
    let lastScroll = 0;
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      if (scrollY > 400 && scrollY > lastScroll) {
        cta.classList.remove('translate-y-full');
      } else if (scrollY < lastScroll || scrollY < 400) {
        cta.classList.add('translate-y-full');
      }
      lastScroll = scrollY;
    }, { passive: true });
  }
</script>
