---
const currentYear = new Date().getFullYear();

const productLinks = [
  { name: 'Disease & Stress Management', href: '/products/disease-stress-management/' },
  { name: 'Feed & Pond Preparers', href: '/products/feed-pond-preparers/' },
  { name: 'Probiotics & Soil Care', href: '/products/probiotics-soil-care/' },
  { name: 'Water Quality & Ammonia Control', href: '/products/water-quality-ammonia-control/' },
];

const companyLinks = [
  { name: 'About Us', href: '/about' },
  { name: 'Contact', href: '/contact' },
  { name: 'Privacy Policy', href: '/privacy' },
  { name: 'Terms of Service', href: '/terms' },
];
---

<footer class="bg-primary-800 text-white">
  <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Company Info -->
      <div>
        <h3 class="text-2xl font-extrabold mb-4">AMRich</h3>
        <p class="text-gray-300 text-sm leading-relaxed mb-4">
          Premium aquaculture solutions scientifically formulated for healthier farms and sustainable yields across Southeast Asia.
        </p>
        <p class="text-gray-400 text-xs">
          Trusted by leading aquaculture farms since 2020.
        </p>
      </div>

      <!-- Products -->
      <div>
        <h4 class="text-lg font-semibold mb-4">Products</h4>
        <ul class="space-y-2">
          {productLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-gray-300 text-sm hover:text-white transition-colors"
              >
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-lg font-semibold mb-4">Contact</h4>
        <ul class="space-y-3">
          <li class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-aqua-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@amrich.netlify.app" class="text-gray-300 text-sm hover:text-white transition-colors">
              info@amrich.netlify.app
            </a>
          </li>
          <li class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-aqua-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-gray-300 text-sm">
              Southeast Asia
            </span>
          </li>
          <li class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-aqua-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span class="text-gray-300 text-sm">
              +60 (0) 12-345-6789
            </span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-10 pt-8 border-t border-primary-700">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <p class="text-gray-400 text-sm">
          &copy; {currentYear} AMRich Aquaculture Solutions. All rights reserved.
        </p>
        <div class="flex space-x-4">
          {companyLinks.map((link) => (
            <a
              href={link.href}
              class="text-gray-400 text-sm hover:text-white transition-colors"
            >
              {link.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>
