---
import { site, productCategories, companyLinks } from '../data/site.ts';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-surface-muted">
  <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-10">
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div class="size-8 rounded-lg bg-gradient-to-br from-brand-500 to-ocean-600 flex items-center justify-center">
            <span class="text-white font-bold text-sm">A</span>
          </div>
          <span class="text-lg font-bold text-ink">Amrich</span>
        </div>
        <p class="text-sm text-ink-light leading-relaxed mb-4 max-w-xs">
          Eco-safe probiotics, water quality solutions, and disease management for shrimp & fish farming in coastal India.
        </p>
        <p class="text-xs text-ink-light/60">
          ISO 9001:2015 Certified &bull; Trusted by 3,000+ farmers across coastal India.
        </p>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-ink mb-4">Products</h4>
        <ul class="space-y-2.5">
          {productCategories.map((cat) => (
            <li>
              <a href={cat.href} class="text-sm text-ink-light hover:text-brand-600 transition-colors">
                {cat.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-ink mb-4">Resources</h4>
        <ul class="space-y-2.5">
          <li><a href="/blog/" class="text-sm text-ink-light hover:text-brand-600 transition-colors">Blog</a></li>
          <li><a href="/case-studies/" class="text-sm text-ink-light hover:text-brand-600 transition-colors">Case Studies</a></li>
          <li><a href="/resources/" class="text-sm text-ink-light hover:text-brand-600 transition-colors">Resource Hub</a></li>
          <li><a href="/faq/" class="text-sm text-ink-light hover:text-brand-600 transition-colors">FAQ</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-ink mb-4">Contact</h4>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="size-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${site.email}`} class="text-sm text-ink-light hover:text-brand-600 transition-colors">
              {site.email}
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="size-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-sm text-ink-light">{site.location}</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="size-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span class="text-sm text-ink-light">{site.phone}</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-border flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-ink-light/60">
        &copy; {currentYear} Amrich Pharma. All rights reserved.
      </p>
      <div class="flex gap-6">
        {companyLinks.map((link) => (
          <a href={link.href} class="text-xs text-ink-light/60 hover:text-brand-600 transition-colors">
            {link.name}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
