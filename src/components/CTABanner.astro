---
interface Props {
  heading?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  heading = 'Ready to Improve Your Farm?',
  description = 'Contact our experts for personalized product recommendations and technical support.',
  ctaLabel = 'Get in Touch',
  ctaHref = '/contact',
} = Astro.props;
---

<section class="bg-gradient-to-r from-brand-600 to-ocean-600 text-white">
  <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="text-center md:text-left">
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-3">
          {heading}
        </h2>
        <p class="text-lg text-white/80 max-w-xl">
          {description}
        </p>
      </div>
      <div class="shrink-0">
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-semibold text-brand-700 bg-white rounded-xl shadow-lg hover:bg-white/90 transition-all duration-200 focus-ring"
        >
          {ctaLabel}
          <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
