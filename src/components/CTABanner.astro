---
interface Props {
  heading?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  heading = 'Ready to Improve Your Farm?',
  description = 'Contact our experts for personalized product recommendations and technical support.',
  ctaLabel = 'Get in Touch',
  ctaHref = '/contact',
} = Astro.props;
---

<section class="bg-gradient-to-r from-aqua-500 to-aqua-600 text-white">
  <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="text-center md:text-left">
        <h2 class="text-3xl md:text-4xl font-extrabold mb-3">
          {heading}
        </h2>
        <p class="text-lg text-white/90 max-w-xl">
          {description}
        </p>
      </div>
      <div class="flex-shrink-0">
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-aqua-600 bg-white rounded-lg shadow-lg hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-white transition-all duration-200"
        >
          {ctaLabel}
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
