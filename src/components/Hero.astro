---
interface Props {
  badge?: string;
  heading?: string;
  subtext?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const {
  badge = 'Trusted by 3,000+ Farmers Across Coastal India',
  heading = 'Way to Go Ahead — <span class="text-brand-400">Aquaculture</span> Health & Care',
  subtext = 'Scientifically formulated products for healthier farms and better yields. From disease management to water quality — we deliver proven results.',
  primaryCta = { label: 'View Products', href: '/products/' },
  secondaryCta = { label: 'Contact Us', href: '/contact' },
} = Astro.props;
---

<section class="relative overflow-hidden bg-gradient-to-br from-brand-900 via-brand-800 to-ocean-900 text-white">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(52,211,153,0.15),transparent_50%)]" />
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,rgba(45,212,191,0.1),transparent_50%)]" />
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-400/30 to-transparent" />

  <div class="relative container-wide mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
    <div class="max-w-3xl">
      {badge && (
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 text-sm font-medium text-brand-300 mb-8">
          <span class="size-1.5 rounded-full bg-brand-400" />
          {badge}
        </div>
      )}

      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6 text-balance" set:html={heading} />

      <p class="text-lg sm:text-xl text-white/70 leading-relaxed mb-10 max-w-2xl">
        {subtext}
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={primaryCta.href}
          class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-semibold text-brand-900 bg-white rounded-xl shadow-lg hover:bg-white/90 transition-all duration-200 focus-ring"
        >
          {primaryCta.label}
          <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href={secondaryCta.href}
          class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-semibold text-white border border-white/20 rounded-xl hover:bg-white/10 transition-all duration-200 focus-ring"
        >
          {secondaryCta.label}
        </a>
      </div>

      <div class="mt-16 flex flex-wrap gap-x-8 gap-y-3 text-sm text-white/50">
        <div class="flex items-center gap-2">
          <svg class="size-4 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Lab-Tested Formulas
        </div>
        <div class="flex items-center gap-2">
          <svg class="size-4 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Environmentally Safe
        </div>
        <div class="flex items-center gap-2">
          <svg class="size-4 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Expert Support
        </div>
      </div>
    </div>
  </div>
</section>
