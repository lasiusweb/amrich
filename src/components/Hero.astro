---
---

<section class="relative bg-gradient-to-br from-primary-800 via-primary-900 to-gray-900 text-white overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25% 25%, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 50px 50px;"></div>
  </div>

  <div class="relative container-wide mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    <div class="max-w-3xl">
      <!-- Badge -->
      <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-white/10 backdrop-blur-sm text-sm font-medium text-aqua-300 mb-6">
        <span class="w-2 h-2 bg-aqua-400 rounded-full mr-2 animate-pulse"></span>
        Trusted by 500+ Farms Across Southeast Asia
      </div>

      <!-- Heading -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
        Premium <span class="text-aqua-400">Aquaculture</span> Solutions
      </h1>

      <!-- Subtext -->
      <p class="text-lg md:text-xl text-gray-300 leading-relaxed mb-8 max-w-2xl">
        Scientifically formulated products for healthier farms and better yields. From disease management to water quality — we deliver proven results.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/products/"
          class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-primary-800 bg-white rounded-lg shadow-lg hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-white transition-all duration-200"
        >
          View Products
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-white transition-all duration-200"
        >
          Contact Us
        </a>
      </div>

      <!-- Trust Indicators -->
      <div class="mt-12 flex flex-wrap gap-8 text-sm text-gray-400">
        <div class="flex items-center space-x-2">
          <svg class="w-5 h-5 text-aqua-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span>Lab-Tested Formulas</span>
        </div>
        <div class="flex items-center space-x-2">
          <svg class="w-5 h-5 text-aqua-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span>Environmentally Safe</span>
        </div>
        <div class="flex items-center space-x-2">
          <svg class="w-5 h-5 text-aqua-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span>Expert Support</span>
        </div>
      </div>
    </div>
  </div>
</section>
