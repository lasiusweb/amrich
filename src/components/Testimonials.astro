---
import { getIcon } from '../data/icons.ts';

const testimonials = [
  {
    quote: 'After using PRO PLUS + GASO CLEAN, ammonia dropped from 2.1 to 0.4 ppm in 5 days. Survival rate improved by 18% this cycle.',
    name: 'Ramesh K.',
    role: 'Commercial Grower',
    location: 'Kakinada, Andhra Pradesh',
  },
  {
    quote: 'FARM 80% cleared gill rot without shocking the pond. Moulting became uniform. Yield per acre went up by 120 kg.',
    name: 'S. Venkat',
    role: 'Mid-Scale Farmer',
    location: 'Nellore, Tamil Nadu',
  },
  {
    quote: 'We were trapped in an antibiotic cycle. GUT-X and FARMADINE helped us break free. Our fish are healthier than ever.',
    name: 'Bharat P.',
    role: 'Farm Manager',
    location: 'Surat, Gujarat',
  },
];
---

<section class="section-padding bg-surface-muted">
  <div class="container-wide">
    <div class="text-center mb-14">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-ink mb-4 text-balance">
        Trusted by Coastal Farmers
      </h2>
      <p class="text-lg text-ink-light max-w-2xl mx-auto">
        Hear from aquaculture professionals who rely on Amrich Pharma products every day.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-surface border border-border rounded-2xl p-8 flex flex-col">
          <div class="flex gap-0.5 mb-5">
            {[...Array(5)].map((_, i) => (
              <span key={i} class="size-4 text-amber-400" set:html={getIcon('star')} />
            ))}
          </div>

          <blockquote class="text-sm text-ink-light leading-relaxed mb-6 flex-1">
            &ldquo;{t.quote}&rdquo;
          </blockquote>

          <div class="pt-4 border-t border-border">
            <div class="font-semibold text-sm text-ink">{t.name}</div>
            <div class="text-xs text-ink-light/70">{t.role} &mdash; {t.location}</div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-xs text-ink-light/60 mb-4 uppercase tracking-widest font-semibold">Serving Farms Across</p>
      <div class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm font-medium text-ink-light">
        <span>Andhra Pradesh</span>
        <span>Tamil Nadu</span>
        <span>Odisha</span>
        <span>Gujarat</span>
        <span>Kerala</span>
      </div>
    </div>
  </div>
</section>
