---
import type { FaqItem } from '../data/faq.ts';

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
};
---

<section class="section-padding">
  <div class="container-wide max-w-3xl">
    <h2 class="font-display text-3xl font-bold text-ink mb-8">Frequently Asked Questions</h2>

    <div class="space-y-4">
      {items.map((item) => (
        <details class="group bg-surface border border-border rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer text-sm font-semibold text-ink hover:text-brand-600 transition-colors [&::-webkit-details-marker]:hidden">
            {item.question}
            <svg class="size-5 text-ink-light shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-6">
            <p class="text-sm text-ink-light leading-relaxed">{item.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
