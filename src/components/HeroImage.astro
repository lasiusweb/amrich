---
export interface Props {
  scene: 'hero' | 'about' | 'sustainability' | 'contact' | 'testimonials' | 'resources' | 'monsoon' | 'quality';
  class?: string;
}
const { scene, class: className = '' } = Astro.props;

const images: Record<string, { src: string; alt: string }> = {
  hero: { src: 'https://imgs.mongabay.com/wp-content/uploads/sites/30/2023/03/30152930/shrimp_farm_NSS04247-1.jpg', alt: 'Aerial view of shrimp farming ponds' },
  about: { src: 'https://www.globalseafood.org/wp-content/uploads/2019/10/India-shrimp-ponds_1500.jpg', alt: 'Indian coastal aquaculture farm' },
  sustainability: { src: 'https://sharangaaqua.com/images/operation4.jpg', alt: 'Sustainable aquaculture practices' },
  contact: { src: 'https://www.aquaculturealliance.org/wp-content/uploads/2019/03/Shrimp-Forum-2019_Pic-1-960x720.jpg', alt: 'Aquaculture expert consulting' },
  testimonials: { src: 'https://www.globalseafood.org/wp-content/uploads/2019/10/India-shrimp-ponds_1500.jpg', alt: 'Happy shrimp farmer with harvest' },
  resources: { src: 'https://www.aquaculturealliance.org/wp-content/uploads/2019/03/Shrimp-Forum-2019_Pic-1-960x720.jpg', alt: 'Aquaculture pond management' },
  monsoon: { src: 'https://imgs.mongabay.com/wp-content/uploads/sites/30/2023/03/30152930/shrimp_farm_NSS04247-1.jpg', alt: 'Monsoon season aquaculture preparation' },
  quality: { src: 'https://sharangaaqua.com/images/operation4.jpg', alt: 'Laboratory quality testing' },
};

const img = images[scene] || images.hero;
---

<img
  src={img.src}
  alt={img.alt}
  class={className}
  width="1200"
  height="675"
  loading={scene === 'hero' ? undefined : 'lazy'}
  fetchpriority={scene === 'hero' ? 'high' : 'auto'}
  decoding="async"
  style="object-fit: cover; width: 100%; height: 100%;"
/>
