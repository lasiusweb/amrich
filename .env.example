# Netlify environment variables for Amrich Pharma
# Copy this file to .env and fill in values

# Webhook URL for quote form submissions (required)
# Point this to your CRM or Netlify function endpoint
PUBLIC_QUOTE_WEBHOOK_URL=https://your-webhook-url-here.com/submit

# Site URL (used for canonical links and OG images)
PUBLIC_SITE_URL=https://amrichpharma.com
